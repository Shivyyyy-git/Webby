---
---
<div id="ask" role="region" aria-label="Ask the AI version of Shivam">
  <div id="ask-pill">
    <div id="ask-icon" aria-hidden="true">S</div>
    <label for="ask-input" class="sr-only">Ask the AI version of Shivam a question</label>
    <input id="ask-input" placeholder="Ask me anything" autocomplete="off" aria-label="Ask the AI version of Shivam a question" />
    <button id="ask-send" type="button" aria-label="Send question"><span aria-hidden="true">→</span></button>
  </div>
  <div id="ask-suggest" role="group" aria-label="Suggested questions">
    <button type="button" class="ask-chip" data-q="What did you actually build at Maya?">What did you build at Maya?</button>
    <button type="button" class="ask-chip" data-q="What's your one metric you can actually defend?">Your one defensible metric?</button>
    <button type="button" class="ask-chip" data-q="Why utility companies?">Why utility companies?</button>
    <button type="button" class="ask-chip" data-q="Tell me about the founder years.">Founder years?</button>
    <button type="button" class="ask-chip" data-q="Are you open to new roles right now?">Open to new roles?</button>
  </div>
  <div id="ask-thread" aria-live="polite"></div>
</div>

<script>
  (() => {
    const input = document.getElementById('ask-input') as HTMLInputElement | null;
    const send  = document.getElementById('ask-send');
    const thread = document.getElementById('ask-thread');
    const ask = document.getElementById('ask');
    if (!input || !ask) return;

    document.querySelectorAll<HTMLButtonElement>('#ask-suggest .ask-chip').forEach((btn) => {
      btn.addEventListener('click', () => {
        const q = btn.dataset.q || btn.textContent || '';
        input.value = q;
        input.focus();
      });
    });

    async function submitQuestion() {
      const q = (input!.value || '').trim();
      if (!q || !thread) return;

      ask!.classList.add('has-thread');

      const u = document.createElement('div');
      u.className = 'msg u';
      u.textContent = q;
      thread.appendChild(u);
      input!.value = '';

      // Loading dots
      const thinking = document.createElement('div');
      thinking.className = 'msg thinking';
      thinking.innerHTML = '<i></i><i></i><i></i>';
      thread.appendChild(thinking);
      thread.scrollTop = thread.scrollHeight;

      try {
        const res = await fetch('/api/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question: q }),
        });
        const data = await res.json();
        thinking.remove();

        const a = document.createElement('div');
        a.className = 'msg a';
        a.textContent = data.answer || 'Reach me at shivamsharma2023@gmail.com';
        thread.appendChild(a);
      } catch {
        thinking.remove();
        const a = document.createElement('div');
        a.className = 'msg a';
        a.textContent = 'Having trouble right now. Email works: shivamsharma2023@gmail.com';
        thread.appendChild(a);
      }

      thread.scrollTop = thread.scrollHeight;
    }

    send?.addEventListener('click', submitQuestion);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); submitQuestion(); }
    });
  })();
</script>

<style>
  #ask {
    position: fixed;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    z-index: 610;
    width: min(640px, calc(100vw - 320px));
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  #ask.live { opacity: 1; pointer-events: auto; }
  #ask-pill {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--ink);
    color: var(--cream);
    border-radius: 99px;
    padding: 8px 8px 8px 16px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
    transition: border-radius 0.35s;
  }
  #ask.expanded #ask-pill { border-radius: 24px; }
  #ask-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--terra);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: 16px;
    color: var(--cream);
    flex-shrink: 0;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 500;
  }
  #ask-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--cream);
    font-family: var(--sans);
    font-size: 14px;
    padding: 8px 0;
  }
  #ask-input::placeholder { color: rgba(237, 228, 211, 0.7); }
  #ask-send {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--terra);
    color: var(--cream);
    border: none;
    font-size: 18px;
    cursor: none;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.2s;
  }
  #ask-send:hover { background: var(--terra-deep); transform: scale(1.05); }
  #ask-suggest {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-top: 10px;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.4s, transform 0.4s;
    pointer-events: none;
  }
  #ask:focus-within #ask-suggest,
  #ask.expanded #ask-suggest {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  .ask-chip {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink);
    background: var(--paper);
    padding: 6px 12px;
    border-radius: 99px;
    border: 1px solid var(--line);
    cursor: none;
    transition: background 0.2s, color 0.2s;
  }
  .ask-chip:hover {
    background: var(--terra);
    color: var(--cream);
    border-color: var(--terra);
  }
  #ask-thread {
    margin-top: 14px;
    background: var(--paper);
    border-radius: 18px;
    padding: 16px;
    max-height: 280px;
    overflow-y: auto;
    display: none;
    border: 1px solid var(--line);
  }
  #ask.has-thread #ask-thread { display: block; }
  .msg { font-size: 14px; line-height: 1.55; padding: 8px 0; }
  .msg.u { color: var(--moss); font-weight: 500; }
  .msg.u::before {
    content: "You · ";
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 400;
    display: block;
    margin-bottom: 2px;
  }
  .msg.a { color: var(--ink); }
  .msg.a::before {
    content: "Shivam (AI) · ";
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 400;
    display: block;
    margin-bottom: 2px;
  }
  .msg.thinking {
    color: var(--muted);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .msg.thinking i {
    width: 5px;
    height: 5px;
    background: var(--terra);
    border-radius: 50%;
    animation: lp 1.2s infinite;
  }
  .msg.thinking i:nth-child(2) { animation-delay: 0.2s; }
  .msg.thinking i:nth-child(3) { animation-delay: 0.4s; }
  @media (max-width: 900px) {
    #ask { width: calc(100vw - 32px); }
  }
</style>
