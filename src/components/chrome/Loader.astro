---
---
<div id="loader">
  <div class="lcap"><span class="dot"></span> Shivam Sharma · Index 2026</div>
  <div class="lcount" id="lcount">00</div>
  <div class="lline"><i id="lline"></i></div>
  <div class="lfoot"><span>Loading the portfolio</span><span id="lpct">0%</span></div>
</div>

<style>
  #loader {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: var(--ink);
    color: var(--cream);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 0 var(--g) 6vh;
    pointer-events: all;
  }
  #loader.gone { pointer-events: none; }
  #loader .lcap {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.5);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  #loader .lcap .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--terra);
    animation: lp 1.4s ease-in-out infinite;
  }
  @keyframes lp {
    0%, 100% { opacity: 0.3; }
    50%      { opacity: 1; }
  }
  #loader .lcount {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(140px, 22vw, 320px);
    font-weight: 300;
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: var(--cream);
    font-variation-settings: 'opsz' 144, 'ital' 1, 'wght' 300;
    margin-bottom: 20px;
  }
  #loader .lline {
    width: min(720px, 80vw);
    height: 1px;
    background: rgba(237, 228, 211, 0.2);
    position: relative;
    overflow: hidden;
  }
  #loader .lline i {
    display: block;
    height: 100%;
    background: var(--terra);
    width: 0%;
  }
  #loader .lfoot {
    margin-top: 24px;
    display: flex;
    justify-content: space-between;
    width: min(720px, 80vw);
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.5);
  }
</style>
