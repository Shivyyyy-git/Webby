<!--
  Atmospheric intro — slow fade + color shift (ink → cream).
  Quiet, cinematic. No counter, no progress bar — just a held italic
  signature, then a long crossfade as the page surface arrives.
-->
<div id="loader">
  <div id="loader-inner">
    <span class="loader-eyebrow"><span class="dot"></span>Index № 01 · 2026</span>
    <span class="loader-mark">Shivam Sharma</span>
    <span class="loader-place">Rochester · ESC Partners · AI PM</span>
  </div>
</div>

<style>
  #loader {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: var(--ink);
    color: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: all;
    transition:
      background 1400ms cubic-bezier(0.4, 0, 0.2, 1),
      color 1400ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 1100ms ease 1500ms;
  }
  #loader.gone { pointer-events: none; }

  /* Phase 1 — color shift (ink → cream). Triggered by JS at ~1.6s */
  #loader.shift {
    background: var(--cream);
    color: var(--ink);
  }

  /* Phase 2 — full fade out (after color shift starts). */
  #loader.fade {
    opacity: 0;
  }

  #loader-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    padding: 0 var(--g);
  }

  /* Eyebrow — appears first, very soft */
  .loader-eyebrow {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: currentColor;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 1.6s ease 0.2s, transform 1.6s ease 0.2s;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .loader-eyebrow .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--terra);
    animation: lp 2.4s ease-in-out infinite;
  }

  /* Main mark — Instrument Serif italic, breathing in */
  .loader-mark {
    font-family: var(--serif-italic);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(54px, 7vw, 110px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: currentColor;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 2s ease 0.55s, transform 2s ease 0.55s;
  }

  /* Place line — quietest, last to arrive */
  .loader-place {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: currentColor;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 1.4s ease 0.95s, transform 1.4s ease 0.95s;
    max-width: 38ch;
  }

  #loader.in .loader-eyebrow,
  #loader.in .loader-mark,
  #loader.in .loader-place {
    opacity: 0.92;
    transform: none;
  }
  #loader.in .loader-eyebrow,
  #loader.in .loader-place {
    opacity: 0.55;
  }

  @media (prefers-reduced-motion: reduce) {
    #loader, .loader-eyebrow, .loader-mark, .loader-place { transition-duration: 0.2s !important; }
  }
</style>
