---
/*
  Greeter — first-visit entry form.
   - Hidden on return visits via localStorage('shivam_greeted').
   - Collects: name, city (optional), email (optional), music preference.
   - On submit:
     1) saves payload to localStorage,
     2) posts to GREETER_WEBHOOK (Google Apps Script Web App, set in greeter.ts),
        non-blocking (best effort),
     3) emits a `greeter:done` window event consumed by bootstrap.ts to
        kick off the atmospheric loader → cinema sequence.
*/
---
<section id="greeter" aria-modal="true" role="dialog" aria-labelledby="greeter-title">
  <div class="greeter-inner">
    <span class="greeter-eyebrow"><span class="dot"></span>Index № 01 · 2026</span>
    <h2 class="greeter-mark" id="greeter-title">Hi.</h2>
    <p class="greeter-sub">
      A quick hello before we begin. <em>None of this is required.</em>
      Skip if you want.
    </p>

    <form class="greeter-form" id="greeter-form" novalidate>
      <label class="g-field">
        <span class="g-label">Your name</span>
        <input class="g-input" type="text" name="name" autocomplete="given-name" placeholder="Type your name" maxlength="60" />
      </label>

      <label class="g-field">
        <span class="g-label">Where are you from? <em>optional</em></span>
        <input class="g-input" type="text" name="city" autocomplete="address-level2" placeholder="e.g. Brooklyn · Mumbai · Berlin" maxlength="80" />
      </label>

      <label class="g-field">
        <span class="g-label">Email <em>optional, only if you want me to write back</em></span>
        <input class="g-input" type="email" name="email" autocomplete="email" placeholder="you@example.com" maxlength="120" />
      </label>

      <fieldset class="g-music">
        <legend class="g-label">Music for the ride</legend>
        <div class="g-radios">
          <label class="g-radio">
            <input type="radio" name="music" value="punjabi" />
            <span class="g-radio-dot"></span>
            <span class="g-radio-label">Punjabi</span>
          </label>
          <label class="g-radio">
            <input type="radio" name="music" value="english" />
            <span class="g-radio-dot"></span>
            <span class="g-radio-label">English</span>
          </label>
          <label class="g-radio">
            <input type="radio" name="music" value="silent" checked />
            <span class="g-radio-dot"></span>
            <span class="g-radio-label">Silent</span>
          </label>
        </div>
      </fieldset>

      <div class="g-actions">
        <button class="g-submit" type="submit">
          <span>Begin the ride</span>
          <span class="g-arrow">→</span>
        </button>
        <button class="g-skip" type="button" id="greeter-skip">Skip the questions</button>
      </div>

      <p class="g-privacy">
        Stays on your device unless you submit.
        <span class="g-sep">·</span>
        No tracking, no cookies.
      </p>
    </form>
  </div>
</section>

<style>
  #greeter {
    position: fixed;
    inset: 0;
    z-index: 9100;  /* above loader (9000) */
    background: var(--ink);
    color: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5vh var(--g);
    overflow-y: auto;
    transition: opacity 0.9s ease, transform 1.0s ease;
  }
  #greeter.gone {
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
  }
  #greeter.hidden {
    display: none;
  }

  .greeter-inner {
    width: min(560px, 100%);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .greeter-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.6);
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 8px;
  }
  .greeter-eyebrow .dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--terra);
    animation: lp 2.4s ease-in-out infinite;
  }

  .greeter-mark {
    font-family: var(--serif-italic);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(54px, 7vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .greeter-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(15px, 1.4vw, 19px);
    color: rgba(237, 228, 211, 0.78);
    line-height: 1.4;
    margin: 0 0 12px;
    max-width: 50ch;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  .greeter-sub em {
    color: var(--terra);
    font-style: italic;
  }

  .greeter-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-top: 6px;
  }

  .g-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .g-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.7);
    font-weight: 500;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .g-label em {
    font-family: var(--serif);
    font-style: italic;
    font-size: 11px;
    text-transform: none;
    letter-spacing: 0;
    color: rgba(237, 228, 211, 0.45);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  .g-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(237, 228, 211, 0.3);
    color: var(--cream);
    font-family: var(--sans);
    font-size: 17px;
    padding: 8px 0;
    transition: border-color 0.25s;
    cursor: none;
  }
  .g-input::placeholder {
    color: rgba(237, 228, 211, 0.35);
  }
  .g-input:focus {
    outline: none;
    border-bottom-color: var(--terra);
  }

  /* Music radios */
  .g-music {
    border: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .g-music .g-label {
    margin-bottom: 0;
  }
  .g-radios {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .g-radio {
    flex: 1 1 0;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border: 1px solid rgba(237, 228, 211, 0.22);
    border-radius: 4px;
    cursor: none;
    transition: border-color 0.25s, background 0.25s;
    min-width: 100px;
  }
  .g-radio:hover {
    border-color: rgba(237, 228, 211, 0.45);
  }
  .g-radio input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .g-radio-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1.5px solid rgba(237, 228, 211, 0.4);
    flex-shrink: 0;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
  }
  .g-radio input:checked ~ .g-radio-dot {
    border-color: var(--terra);
  }
  .g-radio input:checked ~ .g-radio-dot::after {
    content: "";
    position: absolute;
    inset: 3px;
    background: var(--terra);
    border-radius: 50%;
  }
  .g-radio:has(input:checked) {
    border-color: var(--terra);
    background: rgba(194, 90, 58, 0.08);
  }
  .g-radio-label {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cream);
    font-weight: 500;
  }

  /* Actions */
  .g-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .g-submit {
    background: var(--terra);
    color: var(--cream);
    border: none;
    border-radius: 99px;
    padding: 14px 26px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    cursor: none;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: background 0.2s, transform 0.2s;
  }
  .g-submit:hover { background: var(--terra-deep); transform: translateY(-1px); }
  .g-submit .g-arrow {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 400;
  }
  .g-skip {
    background: transparent;
    color: rgba(237, 228, 211, 0.7);
    border: none;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: none;
    padding: 8px 0;
    text-decoration: underline;
    text-decoration-color: rgba(237, 228, 211, 0.2);
    text-underline-offset: 4px;
    transition: color 0.2s;
  }
  .g-skip:hover { color: var(--cream); }

  .g-privacy {
    margin: 4px 0 0;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.4);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .g-sep { opacity: 0.5; }

  /* Reduce on mobile */
  @media (max-width: 720px) {
    .g-radio { padding: 10px 12px; }
    .greeter-mark { font-size: clamp(44px, 12vw, 72px); }
  }
  @media (hover: none) {
    .g-input, .g-radio, .g-submit, .g-skip { cursor: auto; }
  }
</style>
