---
---
<div id="cur"></div>
<div id="cur-ring"></div>
<div id="cur-lbl">Open</div>

<style>
  #cur {
    position: fixed;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--terra);
    z-index: 9999;
    pointer-events: none;
    transform: translate(-50%, -50%);
    transition:
      width 0.3s cubic-bezier(0.2, 0.9, 0.2, 1),
      height 0.3s cubic-bezier(0.2, 0.9, 0.2, 1),
      background 0.25s,
      opacity 0.2s;
    mix-blend-mode: multiply;
    top: 0; left: 0;
  }
  #cur-ring {
    position: fixed;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid var(--ink);
    z-index: 9998;
    pointer-events: none;
    transform: translate(-50%, -50%);
    transition:
      width 0.35s cubic-bezier(0.2, 0.9, 0.2, 1),
      height 0.35s cubic-bezier(0.2, 0.9, 0.2, 1),
      opacity 0.2s;
    top: 0; left: 0;
    mix-blend-mode: multiply;
    opacity: 0.5;
  }
  #cur-lbl {
    position: fixed;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    padding: 6px 10px;
    border-radius: 99px;
    z-index: 9999;
    pointer-events: none;
    transform: translate(-50%, calc(-50% - 36px));
    opacity: 0;
    transition: opacity 0.2s;
    top: 0; left: 0;
  }
  body[data-cur="link"] #cur { width: 48px; height: 48px; background: rgba(194, 90, 58, 0.4); }
  body[data-cur="link"] #cur-ring { opacity: 0; }
  body[data-cur="text"] #cur { width: 2px; height: 22px; border-radius: 1px; background: var(--ink); }
  body[data-cur="proj"] #cur { width: 84px; height: 84px; background: var(--terra); }
  body[data-cur="proj"] #cur-ring { opacity: 0; }
  body[data-cur="proj"] #cur-lbl { opacity: 1; }
  body[data-cur="drag"] #cur { width: 60px; height: 60px; background: rgba(45, 69, 51, 0.3); }
  body[data-cur="drag"] #cur-ring { opacity: 0; }
  body[data-cur="drag"] #cur-lbl { opacity: 1; }
  @media (hover: none) {
    #cur, #cur-ring, #cur-lbl { display: none; }
  }
</style>
