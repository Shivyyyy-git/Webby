---
---
<div id="chrome">
  <span class="mark">Shivam.</span>
  <nav>
    <a href="#receipts">Receipts</a>
    <a href="#work">Work</a>
    <a href="#timeline">Path</a>
    <a href="#phil">Mind</a>
    <a href="#close">Contact</a>
  </nav>
  <div class="right">
    <a class="pill" href="/resume.pdf" target="_blank" rel="noopener" data-cur="link">
      <span class="led live"></span>Open to roles
    </a>
  </div>
</div>

<style>
  #chrome {
    position: fixed;
    top: 22px;  /* clears the Margins ticker */
    left: 0;
    right: 0;
    z-index: 300;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px var(--g);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    pointer-events: none;
    mix-blend-mode: difference;
    color: var(--cream);
  }
  #chrome > * { pointer-events: auto; }
  #chrome .mark {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    letter-spacing: 0;
    text-transform: none;
    font-weight: 400;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  #chrome nav {
    display: flex;
    gap: 26px;
  }
  #chrome nav a {
    color: inherit;
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s;
  }
  #chrome nav a:hover { opacity: 1; }
  #chrome .right {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  #chrome .pill {
    border: 1px solid currentColor;
    padding: 7px 13px;
    border-radius: 99px;
    display: flex;
    gap: 8px;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, color 0.2s;
  }
  #chrome a.pill:hover {
    background: currentColor;
  }
  #chrome a.pill:hover .led,
  #chrome a.pill:hover {
    /* invert on hover via mix-blend; the chrome already uses mix-blend-mode: difference */
  }
  #chrome .led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.6;
  }
  #chrome .led.live {
    background: var(--terra);
    box-shadow: 0 0 8px var(--terra);
    opacity: 1;
    animation: lp 1.6s infinite;
  }
  @media (max-width: 900px) {
    #chrome nav { display: none; }
  }
</style>
