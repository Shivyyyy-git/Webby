---
import { getCollection } from 'astro:content';
const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---
<section id="work">
  <div class="w">
    <div class="cap"><b>Section 03</b> — Selected work</div>

    {/* W O R K — letter-stagger masthead (wodniack.dev port) */}
    <h2 class="work-mast" aria-label="Work">
      <span class="wm-inner" id="wm-inner">
        <span class="wm-letter">W</span>
        <span class="wm-letter">O</span>
        <span class="wm-letter">R</span>
        <span class="wm-letter">K</span>
      </span>
      <span class="wm-meta">
        <span class="wm-count">{String(work.length).padStart(2, '0')} / {String(work.length).padStart(2, '0')}</span>
        <span class="wm-tag">Selected</span>
      </span>
    </h2>

    <div class="work-head reveal">
      <h3 class="work-h">Things I built<br /><em>end-to-end.</em></h3>
      <p class="work-blurb">Five places where I owned product. Maya AI is the headline. Two exits before that taught me the hard parts (hiring, payroll, pricing, the moment a customer says "we're switching"). One PM role and one founding PM role between then and now.</p>
    </div>

    {work.map((entry, i) => {
      const { title, titleEm, role, era, note, tags, stats, accent } = entry.data;
      return (
        <article class={`proj proj--${accent} reveal`} data-cur="proj" data-cur-lbl="Open">
          <div class="proj-num">{String(i + 1).padStart(2, '0')} / {String(work.length).padStart(2, '0')}</div>

          {/* Visual mark — animated gradient + project initials. Stand-in for
              wodniack's video previews; fits the editorial aesthetic. */}
          <div class="proj-visual" aria-hidden="true">
            <span class="pv-grad"></span>
            <span class="pv-noise"></span>
            <span class="pv-mark">{title.charAt(0)}{titleEm.charAt(0).toUpperCase()}</span>
          </div>

          <div>
            <h3 class="proj-name">{title} <em>{titleEm}</em></h3>
            <div class="proj-role">{role} · {era}</div>
          </div>
          <div>
            <p class="proj-desc" set:html={note} />
            <div class="proj-tags">
              {tags.map((t: string) => <span class="proj-tag">{t}</span>)}
            </div>
          </div>
          <div class="proj-stat">
            {stats.map((s: { value: string; label: string }) => (
              <div class="ps">
                <div class="pv">{s.value}</div>
                <div class="pl">{s.label}</div>
              </div>
            ))}
          </div>
          <span class="proj-arrow">→</span>
        </article>
      );
    })}
  </div>
</section>

<style>
  #work {
    padding: 18vh 0 12vh;
    background: var(--ink);
    color: var(--cream);
    position: relative;
  }
  #work .cap { color: rgba(237, 228, 211, 0.5); }
  #work .cap::before { background: var(--terra); }
  /* W O R K letter-stagger masthead */
  .work-mast {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    margin: 52px 0 24px;
    border-bottom: 1px solid rgba(237, 228, 211, 0.18);
    padding-bottom: 20px;
  }
  .wm-inner {
    display: flex;
    gap: clamp(8px, 1.6vw, 28px);
    overflow: hidden;
  }
  .wm-letter {
    font-family: var(--serif);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(72px, 14vw, 220px);
    line-height: 0.86;
    letter-spacing: -0.04em;
    color: var(--cream);
    font-variation-settings: 'opsz' 144, 'ital' 1, 'wght' 300;
    display: inline-block;
    transform: translateY(110%);
    transition: transform 1.0s cubic-bezier(0.2, 0.9, 0.2, 1);
  }
  .wm-letter:nth-child(1) { transition-delay: 0.00s; }
  .wm-letter:nth-child(2) { transition-delay: 0.08s; color: var(--terra); }
  .wm-letter:nth-child(3) { transition-delay: 0.16s; }
  .wm-letter:nth-child(4) { transition-delay: 0.24s; }
  .work-mast.in .wm-letter { transform: translateY(0); }
  .wm-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-end;
    padding-bottom: 18px;
    color: rgba(237, 228, 211, 0.55);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .wm-count {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--terra);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }

  .work-head {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 60px;
    margin: 24px 0 80px;
    align-items: end;
  }
  .work-h {
    font-size: clamp(46px, 7vw, 118px);
    line-height: 0.94;
    letter-spacing: -0.04em;
    color: var(--cream);
    text-wrap: balance;
  }
  .work-blurb {
    font-size: 15px;
    color: rgba(237, 228, 211, 0.65);
    line-height: 1.5;
  }
  .proj {
    display: grid;
    grid-template-columns: 80px 160px 1.3fr 1.5fr 1fr;
    gap: 32px;
    padding: 36px 0;
    border-top: 1px solid rgba(237, 228, 211, 0.15);
    position: relative;
    cursor: none;
    transition: padding 0.5s cubic-bezier(0.2, 0.9, 0.2, 1), background 0.5s;
  }

  /* Visual mark — gradient block per project. Stand-in for wodniack's video previews. */
  .proj-visual {
    position: relative;
    width: 160px;
    height: 100px;
    border-radius: 4px;
    overflow: hidden;
    transform: rotate(-1.2deg) scale(0.95);
    transition: transform 0.6s cubic-bezier(0.2, 0.9, 0.2, 1), box-shadow 0.6s;
    box-shadow: 0 12px 32px -8px rgba(0, 0, 0, 0.4);
  }
  .pv-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--terra) 0%, var(--terra-deep) 60%, var(--rust) 100%);
    transition: transform 1.4s ease;
  }
  .proj--moss .pv-grad { background: linear-gradient(135deg, #5a8a6a 0%, var(--moss) 60%, #15201a 100%); }
  .proj--ink  .pv-grad { background: linear-gradient(135deg, #4a5a52 0%, #2a3a32 60%, #0f1812 100%); }
  .pv-noise {
    position: absolute;
    inset: 0;
    opacity: 0.28;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.45 0 0 0 0 0.4 0 0 0 0 0.35 0 0 0 0.7 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }
  .pv-mark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 46px;
    letter-spacing: -0.03em;
    color: rgba(237, 228, 211, 0.92);
    font-variation-settings: 'opsz' 60, 'ital' 1, 'wght' 300;
    z-index: 2;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }
  .proj:hover .proj-visual {
    transform: rotate(0) scale(1.02);
    box-shadow: 0 24px 48px -10px rgba(0, 0, 0, 0.55);
  }
  .proj:hover .pv-grad {
    transform: scale(1.12);
  }
  .proj:last-child { border-bottom: 1px solid rgba(237, 228, 211, 0.15); }
  .proj-num {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: rgba(237, 228, 211, 0.4);
    padding-top: 8px;
  }
  .proj-name {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(36px, 4.6vw, 68px);
    line-height: 0.96;
    color: var(--cream);
    font-variation-settings: 'opsz' 72, 'wght' 300;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }
  .proj-name em {
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 72, 'ital' 1, 'wght' 300;
  }
  .proj-role {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.5);
    margin-top: 14px;
  }
  .proj-desc {
    font-size: 14.5px;
    color: rgba(237, 228, 211, 0.78);
    line-height: 1.55;
  }
  .proj-desc :global(b) { color: var(--cream); font-weight: 500; }
  .proj-tags {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .proj-tag {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.6);
    padding: 4px 9px;
    border: 1px solid rgba(237, 228, 211, 0.2);
    border-radius: 99px;
  }
  .proj-stat {
    display: flex;
    flex-direction: column;
    gap: 18px;
    align-items: flex-end;
  }
  .proj-stat .ps { text-align: right; }
  .proj-stat .pv {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(28px, 3vw, 46px);
    color: var(--terra);
    line-height: 1;
    font-variation-settings: 'opsz' 60, 'wght' 300;
    letter-spacing: -0.02em;
  }
  .proj-stat .pl {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.5);
    margin-top: 4px;
  }
  .proj-arrow {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%) translateX(40px);
    opacity: 0;
    font-family: var(--serif);
    font-style: italic;
    font-size: 46px;
    color: var(--terra);
    transition: transform 0.5s cubic-bezier(0.2, 0.9, 0.2, 1), opacity 0.4s;
  }
  .proj:hover {
    padding-left: 36px;
    background: linear-gradient(90deg, rgba(194, 90, 58, 0.08), transparent 60%);
  }
  .proj:hover .proj-num { color: var(--terra); }
  .proj:hover .proj-arrow {
    transform: translateY(-50%) translateX(0);
    opacity: 1;
  }
  .proj:hover .proj-name em { color: var(--cream); }
  .proj.in { animation: projIn 0.9s cubic-bezier(0.2, 0.9, 0.2, 1) forwards; }
  @keyframes projIn {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: none; }
  }
  @media (max-width: 900px) {
    .work-mast { flex-direction: column; align-items: flex-start; gap: 16px; }
    .wm-meta { align-items: flex-start; padding-bottom: 0; }
    .work-head { grid-template-columns: 1fr; gap: 24px; }
    .proj { grid-template-columns: 1fr; gap: 14px; }
    .proj-visual { width: 100%; max-width: 320px; height: 120px; transform: none; }
    .proj:hover .proj-visual { transform: scale(1.02); }
  }
</style>
