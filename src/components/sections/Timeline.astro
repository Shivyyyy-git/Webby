---
// Career, chronological (newest first). Center-rail spine, alternating
// sides. Hover any entry → acid wash fills the body card. The floating
// cursor-tracked preview was removed when we shipped without role photos.
const ROLES = [
  {
    side: 'right', now: true,
    date: '2026 · Jan → now', tag: 'NOW',
    title: 'AI Product Manager, ', em: 'ESC Partners',
    where: 'Rochester, NY · Maya AI',
    note: 'Built Maya AI end-to-end. 70 to 80% of first-touch volume on one US utility. Pilot at 40+ agents.',
  },
  {
    side: 'left',
    date: '2025 · Oct → Jan 2026',
    title: 'AI Product Consultant (Builder), ', em: 'Assisted Living Locators',
    where: 'Remote, CA',
    note: 'Owned the matching flow and the agent-facing console.',
  },
  {
    side: 'right',
    date: '2025 · May → Dec',
    title: 'Founding PM, ', em: 'Vollie Inc.',
    where: 'Buffalo, NY (not Pleasanton)',
    note: 'Wrote the first eval suite. Scoped the first three features. Cut what did not fit.',
  },
  {
    side: 'left',
    date: '2025 · Jan → Dec',
    title: 'Product Lead, ', em: 'Ain Center for Entrepreneurship',
    where: 'Simon Business School',
    note: "Built the application stack students used for programs and grants. Ran in parallel with the master's.",
  },
  {
    side: 'right',
    date: '2025 · Dec',
    title: 'M.S. AI in Business ', em: '(STEM)',
    where: 'Simon Business School, Rochester',
    note: "Master's in AI applied to business. Graduated December 2025.",
  },
  {
    side: 'left',
    date: '2019 → 2024',
    title: 'Founder · ', em: 'CloudApproach & Approachables',
    where: 'UK · MENA',
    note: 'Two companies. Two acquisitions. Combined exits of $575K. Influenced roughly $5M in closed deals (deals my team and I drove, not personal revenue).',
  },
];
---
<section id="timeline">
  <div class="w">
    <div class="cap"><b>Section 04</b> · How I got here</div>
    <h2 class="tl-h reveal">Three cities. Two exits.<br />One <em>thread</em>.</h2>

    <!-- Logbook strap above the rail. Was a second H2; collapsed to a single
         meta line so the section has one display headline (`.tl-h`). -->
    <div class="spine-head reveal">
      <div class="spine-eye"><span class="r"></span> LOGBOOK · {ROLES.length} ENTRIES</div>
    </div>

    {/* Center-rail spine. Every role gets a dot on the rail and a body
        card on the alternating side. Hover an entry → body card slides
        away from the rail and fills with acid yellow; the polaroid
        placeholder floats next to the cursor. Photos drop into .frame
        later via the role's `photo` field. */}
    <ol class="spine-rail reveal" id="spine-rail" aria-label="Career timeline, newest first">
      {ROLES.map((r, i) => (
        <li
          class={`lentry ${r.now ? 'now' : ''} ${r.side}`}
          style={`--d:${i * 60}ms`}
        >
          <div class="pin" aria-hidden="true"><div class="d"></div></div>
          <div class="body">
            <p class="date">
              {r.date}
              {r.tag && <span class="tag">{r.tag}</span>}
            </p>
            <h3>{r.title}<em>{r.em}</em></h3>
            {r.where && <p class="where">{r.where}</p>}
            {r.note && <p class="note">{r.note}</p>}
          </div>
        </li>
      ))}
    </ol>

    {/* Floating cursor-tracked preview card was removed — we shipped without
        role photos, so every hover was a "PLACEHOLDER" hatch. Restore from
        git history (look for `#toc-preview`) when real photos exist. */}
  </div>
</section>

<style>
  #timeline {
    padding: 18vh 0 14vh;
    background: var(--paper);
    position: relative;
  }
  .tl-h {
    font-size: clamp(40px, 6vw, 108px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 48px 0 60px;
    text-wrap: balance;
    max-width: 18ch;
  }

  /* ============================================================
     SPINE — center-rail timeline, alt left/right, future/now/past
     ============================================================ */
  .spine-head {
    text-align: center;
    margin: 24px auto 80px;
    max-width: 1100px;
  }
  .spine-eye {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
  }
  .spine-eye .r {
    width: 60px;
    height: 1px;
    background: var(--line);
    display: inline-block;
  }
  /* .spine-h removed — duplicated `.tl-h`. Strap stays as `.spine-eye`. */

  .spine-rail {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 0 60px;
    list-style: none;
  }
  /* Center rail */
  .spine-rail::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--line);
    transform: translateX(-50%);
  }

  .lentry {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 96px 1fr;
    align-items: start;
    padding: 40px 0;
    color: var(--ink);
    list-style: none;
  }

  /* Rail dot */
  .lentry .pin {
    grid-column: 2;
    display: flex;
    justify-content: center;
    padding-top: 14px;
    position: relative;
    z-index: 2;
  }
  .lentry .pin .d {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--paper);
    border: 1.5px solid var(--ink);
    transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.2, 1), background 0.3s, border-color 0.3s;
  }
  .lentry.now .pin .d {
    background: var(--terra);
    border-color: var(--terra);
    box-shadow: 0 0 0 0 rgba(194, 90, 58, 0.6);
    animation: spinePulse 2.2s ease-out infinite;
  }
  @keyframes spinePulse {
    0%   { box-shadow: 0 0 0 0 rgba(194, 90, 58, 0.55); }
    70%  { box-shadow: 0 0 0 20px rgba(194, 90, 58, 0); }
    100% { box-shadow: 0 0 0 0 rgba(194, 90, 58, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lentry.now .pin .d { animation: none; }
  }

  /* Body card — gets the acid wash on hover */
  .lentry .body {
    position: relative;
    overflow: hidden;
    padding: 22px 26px;
    border: 1px solid transparent;
    background: transparent;
    transition: transform 0.45s cubic-bezier(0.2, 0.7, 0.2, 1),
                border-color 0.35s,
                box-shadow 0.45s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .lentry.left  .body { grid-column: 1; text-align: right; margin-right: 4px; }
  .lentry.right .body { grid-column: 3; margin-left: 4px; }
  .lentry .body > * { position: relative; z-index: 1; }

  /* Acid sweep — fills from the rail side toward the outside edge. The
     `--acid` token is defined in tokens.css. */
  .lentry .body::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 0;
    background: var(--acid);
    z-index: 0;
    transition: width 0.5s cubic-bezier(0.5, 0.05, 0.05, 1);
  }
  .lentry.right .body::before { left: 0; }
  .lentry.left  .body::before { right: 0; }

  /* Hover effects */
  @media (hover: hover) {
    .lentry:hover .body {
      border-color: var(--ink);
      box-shadow: 6px 6px 0 var(--ink);
    }
    .lentry.right:hover .body { transform: translateX(12px); box-shadow: 6px 6px 0 var(--ink); }
    .lentry.left:hover  .body { transform: translateX(-12px); box-shadow: -6px 6px 0 var(--ink); }
    .lentry:hover .body::before { width: 100%; }
    .lentry:hover .pin .d { transform: scale(1.35); }
    .lentry:hover h3 em { color: var(--ink); }
  }

  .lentry .date {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .lentry .date .tag {
    border: 1px solid currentColor;
    padding: 2px 9px;
    margin-left: 10px;
    font-size: 10px;
    letter-spacing: 0.22em;
  }
  .lentry.now .date { color: var(--terra); }

  .lentry h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(26px, 2.6vw, 40px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-wrap: balance;
    font-variation-settings: 'opsz' 96, 'wght' 500, 'SOFT' 80;
  }
  .lentry h3 em {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    color: var(--moss);
    font-variation-settings: 'opsz' 96, 'ital' 1, 'wght' 300, 'SOFT' 100;
    transition: color 0.35s;
  }
  .lentry.now h3 em { color: var(--terra); }

  .lentry .where {
    margin-top: 10px;
    font-family: var(--sans);
    font-size: clamp(15px, 1vw, 17px);
    color: var(--ink);
    opacity: 0.72;
  }
  .lentry .note {
    margin-top: 14px;
    font-family: var(--sans);
    font-size: clamp(15.5px, 1.1vw, 18px);
    line-height: 1.55;
    color: var(--ink);
    opacity: 0.86;
    max-width: 44ch;
  }
  .lentry.left .note { margin-left: auto; }

  /* (Floating cursor-tracked preview card removed; see component note above.) */

  @media (max-width: 900px) {
    .spine-eye { gap: 12px; font-size: 10px; }
    .spine-eye .r { width: 28px; }

    /* Collapse the rail to a single left column with all entries on one side */
    .spine-rail::before { left: 14px; }
    .lentry { grid-template-columns: 28px 1fr; padding: 28px 0; }
    .lentry .pin { grid-column: 1; padding-top: 8px; }
    .lentry .body,
    .lentry.left .body,
    .lentry.right .body {
      grid-column: 2;
      text-align: left;
      margin: 0;
      padding: 16px 18px;
    }
    .lentry.left .note { margin-left: 0; }
    .lentry .body::before { left: 0; right: auto; }
    .lentry.left:hover .body,
    .lentry.right:hover .body { transform: translateX(8px); box-shadow: 4px 4px 0 var(--ink); }
  }

</style>
