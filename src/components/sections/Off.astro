---
/*
  FIXME — Off.astro is currently UNHOOKED from src/pages/index.astro per the
  BRIEF: "Off-duty section cut for v1 per brief. Add back later as a short
  editorial P.S. in voice, not a fabricated reading list."

  Before re-hooking this component, verify or replace each CARDS entry:
    - Reading: "Ted Chiang, Jenny Odell, Stories of Your Life" — NOT in BRIEF.
      Confirm these are actually what Shivam reads, or swap for real titles.
    - Listening: "Khruangbin", "tabla loop from a friend's record" —
      NOT in BRIEF. Confirm or replace. The Spotify playlist link in
      Close.astro IS real and could anchor this card factually.
    - Doing: "Marathi food, slow runs" — NOT in BRIEF. Punjabi heritage IS in
      BRIEF §3 (Delhi, Punjab roots). Reconcile or replace.

  BRIEF voice rules that apply when re-writing:
    - No em dashes (this file has already been pre-fixed).
    - Short sentences, Slack-DM tone, not LinkedIn.
    - No "passionate about", "driven by", "obsessed with".
    - If the line could apply to any other PM, rewrite it.
*/
const CARDS = [
  {
    cap: 'Reading',
    h: 'Ted Chiang, Jenny Odell, anything that thinks slow.',
    p: 'Been re-reading "Stories of Your Life" again. Linguistics + free will + a science fiction author who writes one perfect novella a decade.',
    tag: '2026 / now',
  },
  {
    cap: 'Listening',
    h: 'Alt-pop, jazz, and one specific tabla loop.',
    p: "The Spotify card pinned to your screen is the live playlist. Heavy on Khruangbin. The tabla loop is from a friend's record. She's never released it.",
    tag: 'In rotation',
  },
  {
    cap: 'Doing',
    h: 'Marathi food, slow runs, slower writing.',
    p: 'I cook badly, run slowly, write slowly. Amateurs notice more. Mastery is overrated. First contact is where the real insight lives.',
    tag: 'Always',
  },
];
---
<section id="off">
  <div class="w">
    <div class="cap"><b>Section 06</b> · Off-duty</div>
    <h2 class="off-h reveal">When I'm not<br />shipping <em>things.</em></h2>
    <div class="off-grid">
      {CARDS.map((c) => (
        <div class="off-card">
          <div class="cap"><b>{c.cap}</b></div>
          <h3>{c.h}</h3>
          <p>{c.p}</p>
          <span class="tag">{c.tag}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #off {
    padding: 14vh 0;
    background: var(--moss);
    color: var(--cream);
    overflow: hidden;
  }
  #off .cap { color: rgba(237, 228, 211, 0.55); }
  #off .cap::before { background: var(--terra); }
  .off-h {
    font-size: clamp(40px, 6vw, 96px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin: 36px 0 80px;
    color: var(--cream);
    text-wrap: balance;
    max-width: 16ch;
  }
  .off-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 36px;
  }
  .off-card {
    background: var(--cream);
    color: var(--ink);
    padding: 32px;
    border-radius: 6px;
    transition: transform 0.5s cubic-bezier(0.2, 0.9, 0.2, 1), box-shadow 0.5s;
    position: relative;
  }
  .off-card:nth-child(1) { transform: rotate(-1.5deg); }
  .off-card:nth-child(2) { transform: rotate(1deg) translateY(-12px); }
  .off-card:nth-child(3) { transform: rotate(-0.5deg); }
  .off-card:hover {
    transform: rotate(0) translateY(-6px);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.25);
  }
  .off-card .cap { color: var(--muted); }
  .off-card .cap::before { background: var(--terra); }
  .off-card h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(24px, 2.6vw, 34px);
    line-height: 1.1;
    margin-top: 14px;
    color: var(--ink);
    font-variation-settings: 'opsz' 36, 'ital' 1, 'wght' 400;
  }
  .off-card p {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.55;
    margin-top: 14px;
  }
  .off-card .tag {
    position: absolute;
    bottom: 18px;
    right: 18px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  @media (max-width: 900px) {
    .off-grid { grid-template-columns: 1fr; gap: 24px; }
  }
</style>
