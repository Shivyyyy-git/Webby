    align-self: center;
    padding-top: 6px;
  }
  .pc-addr {
    grid-column: 1 / -1;
    grid-row: 3;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2px 8px;
    align-items: end;
    border-top: 1px solid rgba(29, 46, 34, 0.18);
    padding-top: 8px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .pc-addr-to { grid-row: 1; }
  .pc-addr-name {
    grid-row: 1;
    font-family: var(--serif);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0;
    font-size: 13px;
    color: var(--ink);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  .pc-addr-line {
    grid-column: 2;
    grid-row: 2;
    font-size: 8px;
    color: var(--muted);
  }

  /* RAILWAY TRACK — anchored to the bottom of the desk-section, just
     above the cinema bottom letterbox bar (11vh). Caption sits above
     the track with ~4vh of breathing room. */
  #desk-track {
    position: absolute;
    bottom: 13vh;
    left: 0;
    right: 0;
    height: 50px;
    pointer-events: none;
    z-index: 2;
  }
  /* Wooden ties: short horizontal slabs poking out below the single rail.
     --ties-x is written by desk.ts each frame and scrolls the pattern in
     the opposite direction the train is moving — parallax "rush past"
     effect, plus a tiny idle wind so the rail never feels frozen. */
  .track-ties {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 16px;
    background-image: repeating-linear-gradient(
      to right,
      rgba(29, 46, 34, 0.62) 0 4px,
      transparent 4px 22px
    );
    background-position-x: var(--ties-x, 0px);
    background-repeat: repeat;
    opacity: 0.55;
    will-change: background-position;
  }
  /* Single rail — train wheels rest on this. A faint highlight scrolls
     along it in lockstep with the ties so the whole rail reads as moving. */
  .track-rail {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 18px;
    height: 2px;
    background-color: var(--ink);
    background-image: repeating-linear-gradient(
      to right,
      transparent 0 60px,
      rgba(237, 228, 211, 0.35) 60px 64px,
      transparent 64px 124px
    );
    background-position-x: var(--ties-x, 0px);
    opacity: 0.7;
    will-change: background-position;
  }

  .track-station {
    position: absolute;
    bottom: 0;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: auto;
  }
  .st-dot {
    width: 10px;
    height: 10px;
    background: var(--terra);
    border-radius: 50%;
    box-shadow:
      0 0 0 2px var(--cream),
      0 0 0 3.5px var(--ink);
    margin-bottom: 13px;
    transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.2, 1), background 0.3s;
  }
  .track-station[data-live="true"] .st-dot {
    transform: scale(1.6);
    background: var(--terra-deep);
  }
  .st-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 6px;
  }
  .st-label b {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 11px;
    color: var(--terra);
    letter-spacing: 0;
    text-transform: none;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  .track-station[data-live="true"] .st-label {
    color: var(--ink);
  }

  /* TRAIN */
  #desk-train {
    position: absolute;
    bottom: 19px;  /* wheels (≈ 4px from sprite bottom) sit on the rail at bottom: 18px */
    width: 110px;
    height: 33px;
    transform: translate3d(0, 0, 0);
    will-change: transform;
    z-index: 4;
    filter: drop-shadow(0 4px 6px rgba(29, 46, 34, 0.18));
    transition: opacity 0.5s ease;
  }
  /* During cinema, dim the track to ~40% so the caption stays primary —
     but keep the train fully visible so the user sees it pull into each
     station as the autopan progresses. Train chugs through the journey
     while the cinema bars are up. */
  :global(body.cinema) #desk-track {
    opacity: 0.45;
    transition: opacity 0.6s ease;
  }
  :global(body.cinema) .track-station {
    opacity: 0.6;
  }
  :global(body.cinema) #desk-train {
    opacity: 1;
  }
  /* Once cinema ends, hide the lingering caption text completely */
  :global(body.cinema-done) #dc-caption {
    opacity: 0 !important;
    visibility: hidden;
  }
  #desk-train .smoke circle {
    fill: var(--ink);
    opacity: 0;
    transform-origin: 14px 10px;
    animation: train-smoke 2.2s ease-out infinite;
  }
  #desk-train .smoke circle:nth-child(2) { animation-delay: 0.6s; }
  #desk-train .smoke circle:nth-child(3) { animation-delay: 1.2s; }
  @keyframes train-smoke {
    0%   { opacity: 0;    transform: translate(0, 0)    scale(0.6); }
    20%  { opacity: 0.4; }
    100% { opacity: 0;    transform: translate(7px, -22px) scale(1.6); }
  }
  @media (prefers-reduced-motion: reduce) {
    #desk-train .smoke circle { animation: none; opacity: 0; }
  }
  @media (max-width: 720px) {
    #desk-track { bottom: 14vh; height: 44px; }
    .st-label { font-size: 9px; }
    .st-label b { font-size: 11px; }
    #desk-train { width: 90px; height: 27px; }
  }

  /* TAPE */
  .pc-tape {
    position: absolute;
    width: 64px;
    height: 18px;
    background: rgba(212, 180, 140, 0.55);
    z-index: 6;
    pointer-events: none;
    box-shadow: 0 1px 2px rgba(29, 46, 34, 0.12);
    background-image: repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.15) 0 2px, transparent 2px 6px);
  }
  .pc-tape-tl { top: -6px; left: 14%; transform: rotate(-12deg); }
  .pc-tape-tr { top: -6px; right: 14%; transform: rotate(8deg); }
  .pc-tape-bl { bottom: -6px; left: 18%; transform: rotate(6deg); }
  .pc-tape-br { bottom: -6px; right: 18%; transform: rotate(-9deg); }

  /* CINEMA */
  #desk-cine {
    position: fixed;
    inset: 0;
    z-index: 48;
    pointer-events: none;
  }
  body.cinema-done #desk-cine { display: none; }
  .dcb {
    position: absolute;
    left: 0;
    right: 0;
    height: 11vh;
    background: #0a1410;
    z-index: 2;
    transform: translateY(-100%);
    transition: transform 1.1s cubic-bezier(0.7, 0, 0.3, 1);
    box-shadow: 0 0 60px rgba(0, 0, 0, 0.5);
  }
  .dcb.top { top: 0; }
  .dcb.bot { bottom: 0; transform: translateY(100%); }
  :global(body.cinema) .dcb.top { transform: translateY(0); }
  :global(body.cinema) .dcb.bot { transform: translateY(0); }
  .dcb .dcb-meta {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 14px;
    color: rgba(237, 228, 211, 0.85);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    display: flex;
    justify-content: space-between;
    padding: 0 var(--g);
  }
  .dcb.bot .dcb-meta { top: 14px; bottom: auto; }
  .dcb .rec-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--terra);
    margin-right: 8px;
    vertical-align: 1px;
    animation: lp 1.6s ease-in-out infinite;
  }

  /* CAPTION — above the track with breathing room, below the postcards */
  #dc-caption {
    position: absolute;
    left: 50%;
    bottom: 22vh;
    transform: translateX(-50%) translateY(12px);
    width: min(80vw, 1100px);
    text-align: center;
    z-index: 60;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.55s ease, transform 0.7s cubic-bezier(0.2, 0.9, 0.2, 1);
    padding: 0 var(--g);
  }
  #dc-caption.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .dcc-eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 500;
  }
  .dcc-h {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(40px, 6vw, 92px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--ink);
    font-variation-settings: 'opsz' 144, 'wght' 300;
    margin-top: 8px;
    text-wrap: balance;
  }
  .dcc-h em {
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 144, 'ital' 1, 'wght' 300;
  }
  .dcc-p {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(16px, 1.5vw, 22px);
    color: var(--moss);
    margin-top: 12px;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }

  /* SKIP / REPLAY / HINT — relocated to top-LEFT during cinema so they don't
     stack underneath the chrome bar's "Open to roles" pill on the right */
  #dc-skip {
    position: fixed;
    top: 13vh;
    left: var(--g);
    z-index: 55;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.92);
    background: rgba(10, 18, 12, 0.85);
    border: 1px solid rgba(237, 228, 211, 0.35);
    padding: 10px 16px;
    border-radius: 99px;
    cursor: none;
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    transition: opacity 0.5s, background 0.25s, color 0.25s;
  }
  #dc-skip::after {
    content: "›";
    font-family: var(--serif);
    font-size: 14px;
  }
  #dc-skip:hover { background: var(--terra); color: #fff; border-color: var(--terra); }
  :global(body:not(.cinema)) #dc-skip { opacity: 0; pointer-events: none; transform: translateY(-8px); }

  #dc-replay {
    position: absolute;
    top: 24px;
    right: var(--g);
    z-index: 6;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--line);
    padding: 7px 12px;
    border-radius: 99px;
    cursor: none;
    display: flex;
    align-items: center;
    gap: 7px;
    opacity: 0;
    transition: opacity 0.5s, background 0.25s, color 0.25s;
    pointer-events: none;
  }
  #dc-replay::before { content: "◐"; color: var(--terra); }
  #dc-replay:hover { background: var(--ink); color: var(--cream); border-color: var(--ink); }
  :global(body.cinema-done) #dc-replay { opacity: 1; pointer-events: auto; }

  #dc-hint {
    position: absolute;
    left: 50%;
    bottom: 7vh;
    transform: translateX(-50%);
    z-index: 6;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terra);
    opacity: 0;
    transition: opacity 0.8s ease;
    display: flex;
    align-items: center;
    gap: 10px;
    pointer-events: none;
  }

  /* CLOSING KICKER — "where could we go next?" — fades in after cinema-done.
     Sits in the same vertical band as the (now-hidden) cinema caption
     so it lands between the postcards and the train track. */
  #dc-coda {
    position: absolute;
    left: 50%;
    bottom: 22vh;
    transform: translateX(-50%);
    z-index: 7;
    text-align: center;
    pointer-events: none;
    width: min(680px, 85vw);
    display: none;
  }
  :global(body.cinema-done) #dc-coda {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: dc-coda-in 1.4s cubic-bezier(0.2, 0.9, 0.2, 1) 1.2s forwards;
  }
  /* Hide once user starts scrolling past the hero — the coda is a beat,
     not a permanent fixture. */
  :global(body.coda-dismissed) #dc-coda {
    opacity: 0 !important;
    animation: none !important;
    transition: opacity 0.5s ease;
  }
  @keyframes dc-coda-in {
    from { opacity: 0; transform: translateX(-50%) translateY(12px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }
  .dc-coda-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--terra);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .dc-coda-eyebrow::before,
  .dc-coda-eyebrow::after {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--terra);
  }
  .dc-coda-h {
    font-family: var(--serif-italic);
    font-style: italic;
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.1;
    color: var(--ink);
    text-wrap: balance;
  }
  .dc-coda-p {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(14px, 1.2vw, 18px);
    color: var(--moss);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  #dc-hint::before, #dc-hint::after {
    content: "";
    width: 32px;
    height: 1px;
    background: var(--terra);
  }
  :global(body.cinema-done) #dc-hint { opacity: 0.85; animation: hintPulse 2.4s ease-in-out 1.4s infinite; }
  @keyframes hintPulse {
    0%, 100% { opacity: 0.4; }
    50%      { opacity: 0.95; }
  }

  /* AUDIO TOGGLE — sits next to Skip Ride on top-left */
  #aud-tog {
    position: fixed;
    top: 13vh;
    left: calc(var(--g) + 140px);
    z-index: 55;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.92);
    background: rgba(10, 18, 12, 0.85);
    border: 1px solid rgba(237, 228, 211, 0.35);
    padding: 10px 16px;
    border-radius: 99px;
    cursor: none;
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    transition: opacity 0.5s, background 0.25s, color 0.25s;
  }
  #aud-tog:hover { background: var(--terra); color: #fff; border-color: var(--terra); }
  #aud-tog .ad {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--muted);
  }
  #aud-tog.on .ad {
    background: var(--terra);
    box-shadow: 0 0 8px var(--terra);
  }
  :global(body:not(.cinema):not(.cinema-done)) #aud-tog { opacity: 0; pointer-events: none; }

  /* SPREAD MODAL */
  #spread {
    position: fixed;
    inset: 0;
    z-index: 120;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4vh 4vw;
  }
  #spread-bd {
    position: absolute;
    inset: 0;
    background: rgba(10, 18, 12, 0);
    backdrop-filter: blur(0px);
    transition: background 0.55s, backdrop-filter 0.55s;
  }
  #spread.open { pointer-events: auto; }
  #spread.open #spread-bd {
    background: rgba(10, 18, 12, 0.78);
    backdrop-filter: blur(10px);
  }
  #spread-card {
    position: relative;
    width: min(1100px, 92vw);
    max-height: 88vh;
    display: grid;
    grid-template-columns: 46% 54%;
    background: #f7efe0;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 60px 140px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(29, 46, 34, 0.12);
    transform: translateY(60px) rotate(-2deg) scale(0.9);
    opacity: 0;
    transition: transform 0.8s cubic-bezier(0.2, 0.9, 0.2, 1), opacity 0.5s;
  }
  #spread.open #spread-card { transform: translateY(0) rotate(0) scale(1); opacity: 1; }
  .sp-stage { display: contents; }
  .sp-front { position: relative; min-height: 560px; }
  .sp-photo {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: var(--ink);
  }
  .sp-photo .ph-tint { position: absolute; inset: 0; }
  .sp-photo .ph-art { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.55; }
  .sp-photo .ph-grain {
    position: absolute;
    inset: 0;
    opacity: 0.22;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.45 0 0 0 0 0.4 0 0 0 0 0.35 0 0 0 0.7 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }
  .sp-greet {
    position: absolute;
    left: 28px;
    top: 22px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 245, 232, 0.85);
    z-index: 3;
  }
  .sp-city {
    position: absolute;
    left: 28px;
    bottom: 60px;
    right: 28px;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(48px, 5.5vw, 84px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--cream);
    font-variation-settings: 'opsz' 144, 'ital' 1, 'wght' 300;
    z-index: 3;
  }
  .sp-coord {
    position: absolute;
    left: 28px;
    bottom: 24px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(255, 245, 232, 0.65);
    z-index: 3;
  }
  #spread[data-loc="delhi"] .sp-photo .ph-tint { background: linear-gradient(135deg, #c25a3a, #7a3220, #3d1a10); }
  #spread[data-loc="punjab"] .sp-photo .ph-tint { background: linear-gradient(135deg, #d4a85a, #9a6b2a, #5a3818); }
  #spread[data-loc="london"] .sp-photo .ph-tint { background: linear-gradient(135deg, #5a6f7a, #3a4854, #1d2630); }
  #spread[data-loc="usa"] .sp-photo .ph-tint { background: linear-gradient(135deg, #2d4533, #1d2e22, #0a1610); }

  .sp-back {
    padding: 42px 44px 36px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    overflow-y: auto;
    max-height: 88vh;
    position: relative;
    background-image: repeating-linear-gradient(to bottom, transparent 0 26px, rgba(29, 46, 34, 0.05) 26px 27px);
    background-position: 0 90px;
  }
  .sp-stamp { position: absolute; top: 24px; right: 30px; }
  .sp-stamp .pc-stamp-frame { width: 56px; height: 64px; }
  .sp-stamp .pc-stamp-amt { font-size: 18px; }
  .sp-stamp .pc-stamp-flag { width: 28px; height: 18px; }

  .sp-pm {
    position: absolute;
    top: 120px;
    right: 34px;
    width: 120px;
    height: 120px;
    border: 2px solid rgba(29, 46, 34, 0.55);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(29, 46, 34, 0.65);
    transform: rotate(-12deg);
    text-align: center;
    padding: 8px;
    line-height: 1.3;
  }
  .sp-pm .pm-date {
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: rgba(29, 46, 34, 0.85);
    letter-spacing: 0.05em;
    text-transform: none;
    margin: 6px 0;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }

  .sp-body {
    padding-top: 8px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 90%;
  }
  .sp-eyebrow {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--terra);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sp-eyebrow::before {
    content: "";
    width: 20px;
    height: 1px;
    background: var(--terra);
  }
  .sp-h {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(38px, 4vw, 60px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--ink);
    font-variation-settings: 'opsz' 96, 'wght' 300;
  }
  .sp-h em {
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 96, 'ital' 1, 'wght' 300;
  }
  .sp-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
    color: var(--moss);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
    line-height: 1.4;
    max-width: 48ch;
  }
  .sp-p {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink);
    max-width: 50ch;
  }
  .sp-p em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 500;
  }
  /* The grid items are injected via innerHTML in desk.ts (so they don't carry
     Astro's scoped data attributes). Mark these descendants `:global()` so
     the rules actually apply to those dynamic children. */
  .sp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 28px;
    margin-top: 8px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }
  :global(.sp-grid > div) {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  :global(.sp-grid b) {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
  :global(.sp-grid span) {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  .sp-foot {
    margin-top: auto;
    padding-top: 14px;
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .sp-arrows {
    margin-left: auto;
    display: flex;
    gap: 8px;
  }
  .sp-foot button {
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--line);
    padding: 7px 12px;
    border-radius: 99px;
    letter-spacing: 0.16em;
  }
  .sp-foot button:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }
  .sp-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 245, 232, 0.95);
    border: none;
    cursor: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 22px;
    color: var(--ink);
    z-index: 9;
    transition: background 0.25s, transform 0.25s;
  }
  .sp-close:hover { background: var(--terra); color: #fff; transform: rotate(90deg); }

  .hero-scroll {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    animation: bob 2.6s ease-in-out infinite;
    z-index: 6;
  }
  .hero-scroll::after {
    content: "";
    width: 1px;
    height: 36px;
    background: var(--ink);
    opacity: 0.4;
  }
  @keyframes bob {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%      { transform: translateX(-50%) translateY(8px); }
  }

  @media (max-width: 880px) {
    #spread-card { grid-template-columns: 1fr; }
    .sp-front { min-height: 220px; }
    .sp-back { padding: 24px; }
    .sp-stamp, .sp-pm { display: none; }
  }
  @media (max-width: 720px) {
    #desk-strip { padding: 0 8vw; gap: 6vw; }
    .pcard { width: 80vw; }
    #dc-skip, #dc-replay, #dc-hint, #desk-cine, #aud-tog { display: none !important; }
  }

  /* ============================================================
     RIDE — sticky-scroll cinematic journey
     ============================================================ */
  #desk-section[hidden] { display: none; }

  /* While the ride is in view, hide the floating chat + now-playing
     widgets so they don't sit on top of the train. They fade back in
     once the user scrolls past into HeroWords. */
  :global(body.ride-visible) :global(#ask),
  :global(body.ride-visible) :global(#np) {
    opacity: 0 !important;
    pointer-events: none !important;
    transition: opacity 0.4s ease;
  }

  #ride-section {
    position: relative;
    width: 100%;
  }
  #ride-driver {
    /* One viewport per stop, plus one for the closing coda. Outer driver
       provides scroll distance, inner sticky stays put while user scrolls
       through it. */
    position: relative;
    height: calc(100vh * 5);
  }
  #ride-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background:
      linear-gradient(180deg, var(--cream) 0%, var(--cream) 55%, var(--paper-2) 100%);
  }

  /* Landscape ---------------------------------------------------- */
  .ride-hills {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 12vh;
    width: 100%;
    height: 28vh;
    pointer-events: none;
  }
  .ride-hills .hill-far  { fill: var(--sand);    opacity: .35; }
  .ride-hills .hill-mid  { fill: var(--moss);    opacity: .18; }
  .ride-hills .hill-near { fill: var(--ink);     opacity: .12; }
  /* Parallax — JS writes translateX each frame. will-change hint keeps
     the GPU layer warm so it doesn't repaint on every frame. */
  .ride-hills .hill-far,
  .ride-hills .hill-mid,
  .ride-hills .hill-near {
    will-change: transform;
    transform-box: fill-box;
  }

  .ride-ground {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 12vh;
    background: linear-gradient(180deg, var(--paper-2) 0%, var(--sand) 100%);
    opacity: .65;
    pointer-events: none;
  }

  /* HUD ---------------------------------------------------------- */
  .ride-hud {
    position: absolute;
    top: calc(22px + 64px); /* clear margins ticker + chrome */
    left: 0;
    right: 0;
    z-index: 5;
    padding: 12px var(--g);
    display: flex;
    justify-content: space-between;
    gap: 16px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    pointer-events: none;
  }
  .ride-hud .hud-coord { color: var(--gold); }
  .ride-hud .hud-now { color: var(--terra); font-weight: 500; }

  /* Stations ----------------------------------------------------- */
  .ride-stations {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--g);
  }
  .station {
    position: absolute;
    inset: 0;
    opacity: 0;
    /* Filmic ease-out (Apple/cinema curve) — slow finish, gentle landing */
    transform: translateY(24px) scale(0.985);
    transition:
      opacity 0.95s cubic-bezier(0.16, 1, 0.3, 1),
      transform 1.1s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--g);
    will-change: opacity, transform;
  }
  .station.active {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .station-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
    max-width: 1280px;
    width: 100%;
  }
  .station-text { max-width: 640px; }
  .station-num {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terra);
    margin-bottom: 18px;
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .station-num::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--terra);
    display: inline-block;
  }
  .station-h {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(64px, 11vw, 168px);
    line-height: 0.88;
    letter-spacing: -0.055em;
    color: var(--ink);
    font-variation-settings: 'opsz' 144, 'wght' 300;
    text-transform: lowercase;
  }
  .station-h em {
    color: var(--terra);
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'ital' 1, 'wght' 400;
  }
  .station-mood {
    font-family: var(--script);
    font-size: clamp(28px, 3.4vw, 48px);
    color: var(--terra-deep);
    margin-top: 10px;
    line-height: 1;
  }
  .station-body {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.5;
    color: var(--ink);
    max-width: 520px;
    margin-top: 22px;
    font-variation-settings: 'opsz' 36, 'ital' 1, 'wght' 400;
  }
  .station-open {
    margin-top: 26px;
    background: transparent;
    border: 1px solid var(--ink);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 11px 18px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: background 0.2s, color 0.2s;
  }
  .station-open:hover {
    background: var(--ink);
    color: var(--cream);
  }
  .station-open span {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    letter-spacing: 0;
  }

  /* Summary card on right --------------------------------------- */
  .station-card {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 28px 28px 26px;
    box-shadow:
      0 28px 60px -20px rgba(29, 46, 34, 0.18),
      0 4px 10px -4px rgba(29, 46, 34, 0.08);
    display: flex;
    flex-direction: column;
    gap: 6px;
    transform: rotate(1deg);
    max-width: 360px;
    justify-self: end;
  }
  .station-card .card-tape {
    position: absolute;
    top: -10px;
    left: 24px;
    width: 88px;
    height: 18px;
    background: rgba(212, 162, 76, 0.35);
    background-image: repeating-linear-gradient(45deg, rgba(255,255,255,.16) 0 2px, transparent 2px 6px);
    transform: rotate(-3deg);
    box-shadow: 0 1px 2px rgba(29, 46, 34, 0.14);
  }
  .station-card b {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 10px;
  }
  .station-card .yr {
    font-family: var(--serif);
    font-style: italic;
    font-size: 38px;
    color: var(--terra);
    letter-spacing: -0.01em;
    line-height: 1;
    margin: 8px 0 4px;
    font-variation-settings: 'opsz' 144, 'ital' 1, 'wght' 400;
  }
  .station-card .ploc {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 14px;
  }
  .station-card ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .station-card li {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink);
    line-height: 1.45;
  }
  .station-card li::before {
    content: '·';
    color: var(--terra);
    margin-right: 8px;
    font-weight: 700;
