    background:
      radial-gradient(ellipse at 50% 40%, rgba(212, 180, 140, 0.22), transparent 70%),
      linear-gradient(180deg, var(--cream) 0%, #e6d6b8 100%);
  }
  #desk-grain {
    position: absolute;
    inset: 0;
    opacity: 0.10;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='w'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.012' numOctaves='2' seed='4'/%3E%3CfeColorMatrix values='0.6 0 0 0 0.3  0 0.5 0 0 0.22  0 0 0.4 0 0.18  0 0 0 1 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23w)'/%3E%3C/svg%3E");
  }
  #desk-rail {
    position: absolute;
    inset: 0;
    overflow: visible;
    pointer-events: auto;
  }
  #desk-strip {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translate(0, -50%);
    display: flex;
    gap: 5vw;
    padding: 0 18vw;
    align-items: center;
    height: 100%;
    will-change: transform;
    cursor: grab;
  }
  #desk-strip.grab { cursor: grabbing; }

  /* POSTCARD */
  .pcard {
    flex: 0 0 auto;
    width: clamp(380px, 32vw, 520px);
    aspect-ratio: 7 / 4.5;
    position: relative;
    background: var(--paper);
    border-radius: 4px;
    box-shadow: 0 30px 60px -20px rgba(29, 46, 34, 0.35), 0 8px 16px -8px rgba(29, 46, 34, 0.2);
    transition: transform 0.55s cubic-bezier(0.2, 0.9, 0.2, 1), box-shadow 0.55s, filter 0.55s;
    transform: rotate(var(--rot, -1.2deg)) scale(0.9);
    filter: saturate(0.85) brightness(0.96);
    overflow: hidden;
  }
  .pcard.focus {
    transform: rotate(0) scale(1.04);
    filter: none;
    box-shadow: 0 50px 90px -20px rgba(29, 46, 34, 0.45), 0 0 0 1px rgba(194, 90, 58, 0.18);
    z-index: 5;
  }
  .pcard:hover { transform: rotate(0) scale(1.02); filter: none; }
  .pcard.focus:hover { transform: rotate(0) scale(1.06); }

  /* POSTCARD FRONT */
  .pc-front {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: 60% 40%;
  }
  .pc-photo {
    position: relative;
    overflow: hidden;
    background: var(--ink);
  }
  .pc-photo .ph-tint { position: absolute; inset: 0; }
  .pc-photo .ph-grain {
    position: absolute;
    inset: 0;
    opacity: 0.20;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.45 0 0 0 0 0.4 0 0 0 0 0.35 0 0 0 0.7 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }
  .pc-photo .ph-art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.55;
  }
  .pc-stamp-ph {
    position: absolute;
    left: 14px;
    top: 12px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    color: rgba(255, 245, 232, 0.85);
    z-index: 2;
    font-weight: 500;
  }
  .pcard[data-loc="delhi"] .pc-photo .ph-tint { background: linear-gradient(135deg, #c25a3a 0%, #7a3220 60%, #3d1a10 100%); }
  .pcard[data-loc="punjab"] .pc-photo .ph-tint { background: linear-gradient(135deg, #d4a85a 0%, #9a6b2a 50%, #5a3818 100%); }
  .pcard[data-loc="london"] .pc-photo .ph-tint { background: linear-gradient(135deg, #5a6f7a 0%, #3a4854 60%, #1d2630 100%); }
  .pcard[data-loc="usa"] .pc-photo .ph-tint { background: linear-gradient(135deg, #2d4533 0%, #1d2e22 50%, #0a1610 100%); }

  .pc-text {
    padding: 18px 22px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--paper);
    position: relative;
  }
  .pc-text::before {
    content: "";
    position: absolute;
    left: 22px;
    right: 22px;
    top: 0;
    height: 1px;
    background: repeating-linear-gradient(to right, var(--line) 0 4px, transparent 4px 10px);
  }
  .pc-greet {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
