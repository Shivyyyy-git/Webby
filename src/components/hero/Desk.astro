    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 500;
  }

  /* POSTCARD BACK */
  .pc-back {
    position: absolute;
    inset: 0;
    background: #f7efe0;
    background-image:
      linear-gradient(to bottom, transparent 0, transparent calc(100% - 1px), rgba(29, 46, 34, 0.05) 100%),
      repeating-linear-gradient(to bottom, transparent 0 22px, rgba(29, 46, 34, 0.06) 22px 23px);
    padding: 18px 20px;
    opacity: 0;
    pointer-events: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr auto;
    gap: 8px 16px;
  }
  .pc-stamp {
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    align-self: start;
  }
  .pc-stamp-frame {
    width: 48px;
    height: 56px;
    background: #fff;
    border: 2px dashed rgba(29, 46, 34, 0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 4px;
  }
  .pc-stamp-amt {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: 14px;
    color: var(--ink);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 500;
  }
  .pc-stamp-flag {
    width: 22px;
    height: 14px;
    background: linear-gradient(to bottom, #ff9933 0 33%, #fff 33% 67%, #138808 67% 100%);
    position: relative;
  }
  .pc-stamp-flag::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    border: 1px solid #000080;
    transform: translate(-50%, -50%);
  }
  .pc-stamp-flag.uk {
    background: #012169;
  }
  .pc-stamp-flag.uk::after { display: none; }
  .pc-stamp-flag.us {
    background: repeating-linear-gradient(to bottom, #b22234 0 1.5px, #fff 1.5px 3px);
  }
  .pc-stamp-flag.us::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 50%;
    height: 50%;
    background: #3c3b6e;
    border: none;
    border-radius: 0;
    transform: none;
  }
  .pc-postmark {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
  .pc-postmark .pm-date {
    font-family: var(--serif);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: 11px;
    color: rgba(29, 46, 34, 0.75);
  }
  .pc-handwritten {
    grid-column: 1 / -1;
    grid-row: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    line-height: 1.4;
    color: var(--ink);
