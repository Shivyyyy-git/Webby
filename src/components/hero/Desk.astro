---
const POSTCARDS = [
  {
    loc: 'delhi',
    label: 'Delhi · open',
    rotation: '-2.2deg',
    ital: false,
    title: 'Delhi',
    mood: '— Rowdy.',
    stamp: '₹2',
    flag: '',
    pmL: 'DELHI G.P.O.',
    pmDate: '15 · APR · 1995',
    pmR: '★ DEPART ★',
    handwritten: ['born loud, raised loud,', "learned to negotiate before", 'i learned to read.'],
    addrName: "whoever's reading.",
    addrLine: 'somewhere on the internet',
    tape: ['tl', 'br'],
  },
  {
    loc: 'punjab',
    label: 'Punjab · open',
    rotation: '1.6deg',
    ital: true,
    title: 'Punjab',
    mood: '— Roots.',
    stamp: '₹5',
    flag: '',
    pmL: 'JALANDHAR',
    pmDate: 'EVERY · SUMMER',
    pmR: '★ ROOTS ★',
    handwritten: ['family loud at the table.', 'bhangra in the bones,', 'daal on every plate.'],
    addrName: 'anyone with a kitchen.',
    addrLine: 'come hungry.',
    tape: ['tr'],
  },
  {
    loc: 'london',
    label: 'London · open',
    rotation: '-1.4deg',
    ital: false,
    title: 'London',
    mood: '— Schooled.',
    stamp: '£1',
    flag: 'uk',
    pmL: 'CAMBRIDGE',
    pmDate: 'OCT · 2014',
    pmR: '★ STUDY ★',
    handwritten: ['cambridge, then mckinsey.', 'learned the second question', 'is sharper than the first.'],
    addrName: 'my younger self.',
    addrLine: 'slow down. ask twice.',
    tape: ['tl'],
  },
  {
    loc: 'usa',
    label: 'NY/Boston · open',
    rotation: '2.4deg',
    ital: true,
    title: ['New York', 'Boston'],
    mood: '— Shipping.',
    stamp: '$1',
    flag: 'us',
    pmL: 'BOSTON · MA',
    pmDate: 'NOW',
    pmR: '★ NOW ★',
    handwritten: ['two startups, two acquisitions.', 'building maya — civic ai for', '200k residents. still calm-ish.'],
    addrName: 'whoever ships next.',
    addrLine: 'your move.',
    tape: ['tr', 'bl'],
  },
];
---
<div id="desk-section">
  <div id="desk">
    <div id="desk-grain"></div>
    <div id="desk-rail">
      <div id="desk-strip">
        {POSTCARDS.map((p, i) => (
          <article class="pcard" data-loc={p.loc} data-i={i} data-cur="proj" data-cur-lbl={p.label} style={`--rot:${p.rotation}`}>
            <div class="pc-front">
              <div class="pc-photo">
                <div class="ph-tint"></div>
                {p.loc === 'delhi' && (
                  <svg class="ph-art" viewBox="0 0 200 120" preserveAspectRatio="xMidYMid slice">
                    <path d="M0,90 L200,90" stroke="#1d1208" stroke-width="2" opacity=".4" />
                    <circle cx="40" cy="92" r="14" fill="none" stroke="#1d1208" stroke-width="2" opacity=".55" />
                    <circle cx="40" cy="92" r="5" fill="#1d1208" opacity=".55" />
                    <path d="M30,92 L34,60 L60,55 L72,90" fill="none" stroke="#1d1208" stroke-width="2" opacity=".55" />
                    <path d="M120,90 L120,55 L160,55 L160,90" fill="none" stroke="#1d1208" stroke-width="2" opacity=".55" />
                    <path d="M125,55 L155,55 L150,40 L130,40 Z" fill="#1d1208" opacity=".4" />
                    <path d="M132,38 Q128,28 134,18" fill="none" stroke="#1d1208" stroke-width="1.5" opacity=".35" stroke-linecap="round" />
                    <path d="M142,38 Q138,26 144,14" fill="none" stroke="#1d1208" stroke-width="1.5" opacity=".35" stroke-linecap="round" />
                  </svg>
                )}
                {p.loc === 'punjab' && (
                  <svg class="ph-art" viewBox="0 0 200 120" preserveAspectRatio="xMidYMid slice">
                    <circle cx="160" cy="36" r="20" fill="#ffe9b8" opacity=".4" />
                    <path d="M0,90 Q50,82 100,90 Q150,98 200,88" fill="#3d2510" opacity=".4" />
                    <path d="M0,100 Q60,94 100,100 Q150,108 200,98" fill="#3d2510" opacity=".5" />
                    <g stroke="#3d2510" stroke-width="1.2" opacity=".5">
                      <line x1="20" y1="90" x2="20" y2="74" /><line x1="22" y1="76" x2="18" y2="74" />
                      <line x1="40" y1="92" x2="40" y2="72" /><line x1="42" y1="74" x2="38" y2="72" />
                      <line x1="60" y1="90" x2="60" y2="76" /><line x1="62" y1="78" x2="58" y2="76" />
                      <line x1="80" y1="91" x2="80" y2="72" /><line x1="82" y1="74" x2="78" y2="72" />
                      <line x1="100" y1="92" x2="100" y2="74" /><line x1="102" y1="76" x2="98" y2="74" />
                    </g>
                    <ellipse cx="120" cy="60" rx="18" ry="11" fill="#3d2510" opacity=".5" />
                    <path d="M102,60 Q102,44 120,38 Q138,44 138,60" fill="#3d2510" opacity=".55" />
                  </svg>
                )}
                {p.loc === 'london' && (
                  <svg class="ph-art" viewBox="0 0 200 120" preserveAspectRatio="xMidYMid slice">
                    <line x1="0" y1="90" x2="200" y2="90" stroke="#0a1018" stroke-width="2" opacity=".4" />
                    <rect x="34" y="34" width="22" height="60" fill="none" stroke="#0a1018" stroke-width="1.5" opacity=".5" />
                    <polygon points="34,34 56,34 45,18" fill="#0a1018" opacity=".5" />
                    <circle cx="45" cy="50" r="5" fill="none" stroke="#0a1018" stroke-width="1" opacity=".55" />
                    <line x1="45" y1="50" x2="45" y2="46" stroke="#0a1018" stroke-width="1" opacity=".55" />
                    <line x1="45" y1="50" x2="48" y2="50" stroke="#0a1018" stroke-width="1" opacity=".55" />
                    <path d="M70,90 Q120,70 170,90" fill="none" stroke="#0a1018" stroke-width="1.5" opacity=".5" />
                    <line x1="80" y1="83" x2="80" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <line x1="100" y1="78" x2="100" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <line x1="120" y1="76" x2="120" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <line x1="140" y1="78" x2="140" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <line x1="160" y1="83" x2="160" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <g stroke="#dde6ec" stroke-width="0.6" opacity=".25">
                      <line x1="10" y1="0" x2="20" y2="20" /><line x1="50" y1="0" x2="60" y2="20" /><line x1="90" y1="0" x2="100" y2="20" /><line x1="130" y1="0" x2="140" y2="20" /><line x1="170" y1="0" x2="180" y2="20" />
                    </g>
                  </svg>
                )}
                {p.loc === 'usa' && (
                  <svg class="ph-art" viewBox="0 0 200 120" preserveAspectRatio="xMidYMid slice">
                    <g fill="#0a0d08" opacity=".55">
                      <rect x="10" y="50" width="14" height="48" />
                      <rect x="28" y="38" width="18" height="60" />
                      <rect x="50" y="58" width="12" height="40" />
                      <rect x="66" y="22" width="22" height="76" />
                      <rect x="92" y="44" width="14" height="54" />
                      <rect x="110" y="32" width="20" height="66" />
                      <rect x="134" y="56" width="12" height="42" />
                      <rect x="150" y="40" width="18" height="58" />
                      <rect x="172" y="60" width="14" height="38" />
                    </g>
                    <g fill="#ffd97a" opacity=".7">
                      <rect x="32" y="44" width="3" height="3" /><rect x="38" y="50" width="3" height="3" />
                      <rect x="70" y="30" width="3" height="3" /><rect x="76" y="40" width="3" height="3" /><rect x="82" y="50" width="3" height="3" />
                      <rect x="114" y="40" width="3" height="3" /><rect x="120" y="48" width="3" height="3" />
                      <rect x="154" y="48" width="3" height="3" /><rect x="160" y="56" width="3" height="3" />
                    </g>
                    <line x1="0" y1="100" x2="200" y2="100" stroke="#c25a3a" stroke-width="1.2" opacity=".7" />
                  </svg>
                )}
                <div class="ph-grain"></div>
                <div class="pc-stamp-ph">{p.loc === 'usa' ? 'NY · BOS' : p.loc.toUpperCase()}</div>
              </div>
              <div class="pc-text">
                <span class="pc-greet">Greetings from</span>
                {Array.isArray(p.title) ? (
                  <>
                    <h3 class={`pc-city ${p.ital ? 'ital' : ''}`}>{p.title[0]}<span class="pc-amp"> /</span></h3>
                    <h3 class={`pc-city ${p.ital ? 'ital' : ''}`}>{p.title[1]}<span class="pc-amp">.</span></h3>
                  </>
                ) : (
                  <h3 class={`pc-city ${p.ital ? 'ital' : ''}`}>{p.title}<span class="pc-amp">.</span></h3>
                )}
                <span class="pc-mood">{p.mood}</span>
              </div>
            </div>
            <div class="pc-back">
              <div class="pc-stamp">
                <div class="pc-stamp-frame">
                  <span class="pc-stamp-amt">{p.stamp}</span>
                  <span class={`pc-stamp-flag ${p.flag}`}></span>
                </div>
              </div>
              <div class="pc-postmark">
                <span>{p.pmL}</span><span class="pm-date">{p.pmDate}</span><span>{p.pmR}</span>
              </div>
              <div class="pc-handwritten">
                {p.handwritten.map((line) => <span class="pc-hw-line">{line}</span>)}
              </div>
              <div class="pc-addr">
                <span class="pc-addr-to">To:</span>
                <span class="pc-addr-name">{p.addrName}</span>
                <span class="pc-addr-line">{p.addrLine}</span>
              </div>
            </div>
            {p.tape.map((t) => <div class={`pc-tape pc-tape-${t}`}></div>)}
          </article>
        ))}

        {/* RAILWAY TRACK — single side-view rail with ties below */}
        <div id="desk-track" aria-hidden="true">
          <div class="track-ties"></div>
          <div class="track-rail"></div>
          {POSTCARDS.map((p, i) => (
            <div class="track-station" data-i={i}>
              <span class="st-dot"></span>
              <span class="st-label">
                <b>{String(i + 1).padStart(2, '0')}</b>
                {p.loc === 'usa' ? 'NY · BOS' : p.loc.charAt(0).toUpperCase() + p.loc.slice(1)}
              </span>
            </div>
          ))}
          <svg id="desk-train" viewBox="0 0 160 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <g class="smoke">
              <circle cx="14" cy="10" r="2.5" />
              <circle cx="11" cy="6"  r="3" />
              <circle cx="16" cy="2"  r="3.5" />
            </g>
            {/* Locomotive */}
            <rect x="2"  y="18" width="44" height="22" rx="2" fill="#1d2e22" />
            <rect x="6"  y="13" width="14" height="6" fill="#1d2e22" />
            <rect x="11" y="8"  width="6"  height="6" fill="#1d2e22" />
            <rect x="32" y="22" width="8"  height="8" fill="#ede4d3" />
            <rect x="0"  y="31" width="48" height="2" fill="#c25a3a" />
            {/* Coupler 1 */}
            <rect x="46" y="28" width="6" height="2" fill="#1d2e22" />
            {/* Carriage 1 */}
            <rect x="50" y="21" width="48" height="19" rx="1.5" fill="#c25a3a" />
            <rect x="56" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="66" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="76" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="86" y="24" width="6" height="6" fill="#ede4d3" />
            {/* Coupler 2 */}
            <rect x="96" y="28" width="6" height="2" fill="#1d2e22" />
            {/* Carriage 2 */}
            <rect x="100" y="21" width="48" height="19" rx="1.5" fill="#2d4533" />
            <rect x="106" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="116" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="126" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="136" y="24" width="6" height="6" fill="#ede4d3" />
            {/* Wheels */}
            <circle cx="10"  cy="42" r="4"   fill="#1d2e22" />
            <circle cx="36"  cy="42" r="4"   fill="#1d2e22" />
            <circle cx="60"  cy="42" r="3.2" fill="#1d2e22" />
            <circle cx="88"  cy="42" r="3.2" fill="#1d2e22" />
            <circle cx="110" cy="42" r="3.2" fill="#1d2e22" />
            <circle cx="138" cy="42" r="3.2" fill="#1d2e22" />
          </svg>
        </div>
      </div>
    </div>

    <div id="desk-cine">
      <div class="dcb top">
        <div class="dcb-meta">
          <span><span class="rec-dot"></span>REC · Roots Reel · 4 stops</span>
          <span id="dc-counter">stop 01 · of 04</span>
        </div>
      </div>
      <div class="dcb bot">
        <div class="dcb-meta">
          <span>auto-pan · click any postcard to open</span>
          <span id="dc-loc">Delhi → Boston</span>
        </div>
      </div>
    </div>

    <button id="dc-skip">skip ride</button>
    <button id="aud-tog"><span class="ad"></span>sound off</button>
    <button id="dc-replay">replay</button>
    <div id="dc-hint">drag the strip · click any postcard</div>

    <div id="dc-caption">
      <span class="dcc-eyebrow" id="dcc-eyebrow">stop 01 · 1995</span>
      <h2 class="dcc-h" id="dcc-h">Delhi.</h2>
      <p class="dcc-p" id="dcc-p">born loud · raised loud</p>
    </div>
  </div>

  <div class="hero-scroll">scroll · or drag the postcards</div>
</div>

<!-- POSTCARD SPREAD MODAL -->
<div id="spread">
  <div id="spread-bd"></div>
  <div id="spread-card">
    <button class="sp-close" id="sp-close" aria-label="Close">×</button>
    <div class="sp-stage">
      <div class="sp-front">
        <div class="sp-photo">
          <div class="ph-tint"></div>
          <svg class="ph-art" id="sp-art" viewBox="0 0 200 120" preserveAspectRatio="xMidYMid slice"></svg>
          <div class="ph-grain"></div>
          <div class="sp-greet">Greetings from</div>
          <div class="sp-city" id="sp-city">City.</div>
          <div class="sp-coord" id="sp-coord">— · —</div>
        </div>
      </div>
      <div class="sp-back">
        <div class="sp-stamp">
          <div class="pc-stamp-frame">
            <span class="pc-stamp-amt" id="sp-stamp-amt">₹2</span>
            <span class="pc-stamp-flag" id="sp-stamp-flag"></span>
          </div>
        </div>
        <div class="sp-pm">
          <span id="sp-pm-l">CITY G.P.O.</span><span class="pm-date" id="sp-pm-date">DATE</span><span id="sp-pm-r">★ STAR ★</span>
        </div>
        <div class="sp-body">
          <div class="sp-eyebrow" id="sp-eyebrow">Stop 01 · Roots Reel</div>
          <h2 class="sp-h" id="sp-h">City. <em>Mood.</em></h2>
          <p class="sp-sub" id="sp-sub"></p>
          <p class="sp-p" id="sp-p1"></p>
          <p class="sp-p" id="sp-p2"></p>
          <div class="sp-grid" id="sp-grid"></div>
          <div class="sp-foot">
            <span id="sp-foot-tag">stop · 01 of 04</span>
            <div class="sp-arrows">
              <button id="sp-prev" data-cur="link">‹ prev card</button>
              <button id="sp-next" data-cur="link">next card ›</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* DESK BACKDROP */
  #desk-section {
    position: relative;
    height: 100vh;
    width: 100%;
  }
  #desk {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 40%, rgba(212, 180, 140, 0.22), transparent 70%),
      linear-gradient(180deg, var(--cream) 0%, #e6d6b8 100%);
  }
  #desk-grain {
    position: absolute;
    inset: 0;
    opacity: 0.10;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='w'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.012' numOctaves='2' seed='4'/%3E%3CfeColorMatrix values='0.6 0 0 0 0.3  0 0.5 0 0 0.22  0 0 0.4 0 0.18  0 0 0 1 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23w)'/%3E%3C/svg%3E");
  }
  #desk-rail {
    position: absolute;
    inset: 0;
    overflow: visible;
    pointer-events: auto;
  }
  #desk-strip {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translate(0, -50%);
    display: flex;
    gap: 5vw;
    padding: 0 18vw;
    align-items: center;
    height: 100%;
    will-change: transform;
    cursor: grab;
  }
  #desk-strip.grab { cursor: grabbing; }

  /* POSTCARD */
  .pcard {
    flex: 0 0 auto;
    width: clamp(380px, 32vw, 520px);
    aspect-ratio: 7 / 4.5;
    position: relative;
    background: var(--paper);
    border-radius: 4px;
    box-shadow: 0 30px 60px -20px rgba(29, 46, 34, 0.35), 0 8px 16px -8px rgba(29, 46, 34, 0.2);
    transition: transform 0.55s cubic-bezier(0.2, 0.9, 0.2, 1), box-shadow 0.55s, filter 0.55s;
    transform: rotate(var(--rot, -1.2deg)) scale(0.9);
    filter: saturate(0.85) brightness(0.96);
    overflow: hidden;
  }
  .pcard.focus {
    transform: rotate(0) scale(1.04);
    filter: none;
    box-shadow: 0 50px 90px -20px rgba(29, 46, 34, 0.45), 0 0 0 1px rgba(194, 90, 58, 0.18);
    z-index: 5;
  }
  .pcard:hover { transform: rotate(0) scale(1.02); filter: none; }
  .pcard.focus:hover { transform: rotate(0) scale(1.06); }

  /* POSTCARD FRONT */
  .pc-front {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: 60% 40%;
  }
  .pc-photo {
    position: relative;
    overflow: hidden;
    background: var(--ink);
  }
  .pc-photo .ph-tint { position: absolute; inset: 0; }
  .pc-photo .ph-grain {
    position: absolute;
    inset: 0;
    opacity: 0.20;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.45 0 0 0 0 0.4 0 0 0 0 0.35 0 0 0 0.7 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }
  .pc-photo .ph-art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.55;
  }
  .pc-stamp-ph {
    position: absolute;
    left: 14px;
    top: 12px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    color: rgba(255, 245, 232, 0.85);
    z-index: 2;
    font-weight: 500;
  }
  .pcard[data-loc="delhi"] .pc-photo .ph-tint { background: linear-gradient(135deg, #c25a3a 0%, #7a3220 60%, #3d1a10 100%); }
  .pcard[data-loc="punjab"] .pc-photo .ph-tint { background: linear-gradient(135deg, #d4a85a 0%, #9a6b2a 50%, #5a3818 100%); }
  .pcard[data-loc="london"] .pc-photo .ph-tint { background: linear-gradient(135deg, #5a6f7a 0%, #3a4854 60%, #1d2630 100%); }
  .pcard[data-loc="usa"] .pc-photo .ph-tint { background: linear-gradient(135deg, #2d4533 0%, #1d2e22 50%, #0a1610 100%); }

  .pc-text {
    padding: 18px 22px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--paper);
    position: relative;
  }
  .pc-text::before {
    content: "";
    position: absolute;
    left: 22px;
    right: 22px;
    top: 0;
    height: 1px;
    background: repeating-linear-gradient(to right, var(--line) 0 4px, transparent 4px 10px);
  }
  .pc-greet {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
  .pc-city {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(34px, 3.4vw, 52px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--ink);
    font-variation-settings: 'opsz' 96, 'wght' 300;
    margin-top: 2px;
  }
  .pc-city.ital {
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 96, 'ital' 1, 'wght' 300;
  }
  .pc-amp { color: var(--terra); }
  .pc-mood {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: var(--moss);
    margin-top: 4px;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 500;
  }

  /* POSTCARD BACK */
  .pc-back {
    position: absolute;
    inset: 0;
    background: #f7efe0;
    background-image:
      linear-gradient(to bottom, transparent 0, transparent calc(100% - 1px), rgba(29, 46, 34, 0.05) 100%),
      repeating-linear-gradient(to bottom, transparent 0 22px, rgba(29, 46, 34, 0.06) 22px 23px);
    padding: 18px 20px;
    opacity: 0;
    pointer-events: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr auto;
    gap: 8px 16px;
  }
  .pc-stamp {
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    align-self: start;
  }
  .pc-stamp-frame {
    width: 48px;
    height: 56px;
    background: #fff;
    border: 2px dashed rgba(29, 46, 34, 0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 4px;
  }
  .pc-stamp-amt {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: 14px;
    color: var(--ink);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 500;
  }
  .pc-stamp-flag {
    width: 22px;
    height: 14px;
    background: linear-gradient(to bottom, #ff9933 0 33%, #fff 33% 67%, #138808 67% 100%);
    position: relative;
  }
  .pc-stamp-flag::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    border: 1px solid #000080;
    transform: translate(-50%, -50%);
  }
  .pc-stamp-flag.uk {
    background: #012169;
  }
  .pc-stamp-flag.uk::after { display: none; }
  .pc-stamp-flag.us {
    background: repeating-linear-gradient(to bottom, #b22234 0 1.5px, #fff 1.5px 3px);
  }
  .pc-stamp-flag.us::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 50%;
    height: 50%;
    background: #3c3b6e;
    border: none;
    border-radius: 0;
    transform: none;
  }
  .pc-postmark {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
  .pc-postmark .pm-date {
    font-family: var(--serif);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: 11px;
    color: rgba(29, 46, 34, 0.75);
  }
  .pc-handwritten {
    grid-column: 1 / -1;
    grid-row: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    line-height: 1.4;
    color: var(--ink);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
    align-self: center;
    padding-top: 6px;
  }
  .pc-addr {
    grid-column: 1 / -1;
    grid-row: 3;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2px 8px;
    align-items: end;
    border-top: 1px solid rgba(29, 46, 34, 0.18);
    padding-top: 8px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .pc-addr-to { grid-row: 1; }
  .pc-addr-name {
    grid-row: 1;
    font-family: var(--serif);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0;
    font-size: 13px;
    color: var(--ink);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  .pc-addr-line {
    grid-column: 2;
    grid-row: 2;
    font-size: 8px;
    color: var(--muted);
  }

  /* RAILWAY TRACK — anchored to the bottom of the desk-section, just
     above the cinema bottom letterbox bar (11vh). Caption sits above
     the track with ~4vh of breathing room. */
  #desk-track {
    position: absolute;
    bottom: 13vh;
    left: 0;
    right: 0;
    height: 50px;
    pointer-events: none;
    z-index: 2;
  }
  /* Wooden ties: short horizontal slabs poking out below the single rail */
  .track-ties {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 16px;
    background: repeating-linear-gradient(
      to right,
      rgba(29, 46, 34, 0.62) 0 4px,
      transparent 4px 22px
    );
    opacity: 0.55;
  }
  /* Single rail — train wheels rest on this */
  .track-rail {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 18px;
    height: 2px;
    background: var(--ink);
    opacity: 0.65;
  }

  .track-station {
    position: absolute;
    bottom: 0;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: auto;
  }
  .st-dot {
    width: 10px;
    height: 10px;
    background: var(--terra);
    border-radius: 50%;
    box-shadow:
      0 0 0 2px var(--cream),
      0 0 0 3.5px var(--ink);
    margin-bottom: 13px;
    transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.2, 1), background 0.3s;
  }
  .track-station[data-live="true"] .st-dot {
    transform: scale(1.6);
    background: var(--terra-deep);
  }
  .st-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 6px;
  }
  .st-label b {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 11px;
    color: var(--terra);
    letter-spacing: 0;
    text-transform: none;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  .track-station[data-live="true"] .st-label {
    color: var(--ink);
  }

  /* TRAIN */
  #desk-train {
    position: absolute;
    bottom: 19px;  /* wheels (≈ 4px from sprite bottom) sit on the rail at bottom: 18px */
    width: 110px;
    height: 33px;
    transform: translate3d(0, 0, 0);
    will-change: transform;
    z-index: 4;
    filter: drop-shadow(0 4px 6px rgba(29, 46, 34, 0.18));
    transition: opacity 0.5s ease;
  }
  /* During cinema, dim the track to ~40% so the caption stays primary —
     but keep the train fully visible so the user sees it pull into each
     station as the autopan progresses. Train chugs through the journey
     while the cinema bars are up. */
  :global(body.cinema) #desk-track {
    opacity: 0.45;
    transition: opacity 0.6s ease;
  }
  :global(body.cinema) .track-station {
    opacity: 0.6;
  }
  :global(body.cinema) #desk-train {
    opacity: 1;
  }
  /* Once cinema ends, hide the lingering caption text completely */
  :global(body.cinema-done) #dc-caption {
    opacity: 0 !important;
    visibility: hidden;
  }
  #desk-train .smoke circle {
    fill: var(--ink);
    opacity: 0;
    transform-origin: 14px 10px;
    animation: train-smoke 2.2s ease-out infinite;
  }
  #desk-train .smoke circle:nth-child(2) { animation-delay: 0.6s; }
  #desk-train .smoke circle:nth-child(3) { animation-delay: 1.2s; }
  @keyframes train-smoke {
    0%   { opacity: 0;    transform: translate(0, 0)    scale(0.6); }
    20%  { opacity: 0.4; }
    100% { opacity: 0;    transform: translate(7px, -22px) scale(1.6); }
  }
  @media (prefers-reduced-motion: reduce) {
    #desk-train .smoke circle { animation: none; opacity: 0; }
  }
  @media (max-width: 720px) {
    #desk-track { bottom: 14vh; height: 44px; }
    .st-label { font-size: 9px; }
    .st-label b { font-size: 11px; }
    #desk-train { width: 90px; height: 27px; }
  }

  /* TAPE */
  .pc-tape {
    position: absolute;
    width: 64px;
    height: 18px;
    background: rgba(212, 180, 140, 0.55);
    z-index: 6;
    pointer-events: none;
    box-shadow: 0 1px 2px rgba(29, 46, 34, 0.12);
    background-image: repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.15) 0 2px, transparent 2px 6px);
  }
  .pc-tape-tl { top: -6px; left: 14%; transform: rotate(-12deg); }
  .pc-tape-tr { top: -6px; right: 14%; transform: rotate(8deg); }
  .pc-tape-bl { bottom: -6px; left: 18%; transform: rotate(6deg); }
  .pc-tape-br { bottom: -6px; right: 18%; transform: rotate(-9deg); }

  /* CINEMA */
  #desk-cine {
    position: fixed;
    inset: 0;
    z-index: 48;
    pointer-events: none;
  }
  body.cinema-done #desk-cine { display: none; }
  .dcb {
    position: absolute;
    left: 0;
    right: 0;
    height: 11vh;
    background: #0a1410;
    z-index: 2;
    transform: translateY(-100%);
    transition: transform 1.1s cubic-bezier(0.7, 0, 0.3, 1);
    box-shadow: 0 0 60px rgba(0, 0, 0, 0.5);
  }
  .dcb.top { top: 0; }
  .dcb.bot { bottom: 0; transform: translateY(100%); }
  :global(body.cinema) .dcb.top { transform: translateY(0); }
  :global(body.cinema) .dcb.bot { transform: translateY(0); }
  .dcb .dcb-meta {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 14px;
    color: rgba(237, 228, 211, 0.85);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    display: flex;
    justify-content: space-between;
    padding: 0 var(--g);
  }
  .dcb.bot .dcb-meta { top: 14px; bottom: auto; }
  .dcb .rec-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--terra);
    margin-right: 8px;
    vertical-align: 1px;
    animation: lp 1.6s ease-in-out infinite;
  }

  /* CAPTION — above the track with breathing room, below the postcards */
  #dc-caption {
    position: absolute;
    left: 50%;
    bottom: 22vh;
    transform: translateX(-50%) translateY(12px);
    width: min(80vw, 1100px);
    text-align: center;
    z-index: 60;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.55s ease, transform 0.7s cubic-bezier(0.2, 0.9, 0.2, 1);
    padding: 0 var(--g);
  }
  #dc-caption.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .dcc-eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 500;
  }
  .dcc-h {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(40px, 6vw, 92px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--ink);
    font-variation-settings: 'opsz' 144, 'wght' 300;
    margin-top: 8px;
    text-wrap: balance;
  }
  .dcc-h em {
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 144, 'ital' 1, 'wght' 300;
  }
  .dcc-p {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(16px, 1.5vw, 22px);
    color: var(--moss);
    margin-top: 12px;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }

  /* SKIP / REPLAY / HINT — relocated to top-LEFT during cinema so they don't
     stack underneath the chrome bar's "Open to roles" pill on the right */
  #dc-skip {
    position: fixed;
    top: 13vh;
    left: var(--g);
    z-index: 55;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.92);
    background: rgba(10, 18, 12, 0.85);
    border: 1px solid rgba(237, 228, 211, 0.35);
    padding: 10px 16px;
    border-radius: 99px;
    cursor: none;
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    transition: opacity 0.5s, background 0.25s, color 0.25s;
  }
  #dc-skip::after {
    content: "›";
    font-family: var(--serif);
    font-size: 14px;
  }
  #dc-skip:hover { background: var(--terra); color: #fff; border-color: var(--terra); }
  :global(body:not(.cinema)) #dc-skip { opacity: 0; pointer-events: none; transform: translateY(-8px); }

  #dc-replay {
    position: absolute;
    top: 24px;
    right: var(--g);
    z-index: 6;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--line);
    padding: 7px 12px;
    border-radius: 99px;
    cursor: none;
    display: flex;
    align-items: center;
    gap: 7px;
    opacity: 0;
    transition: opacity 0.5s, background 0.25s, color 0.25s;
    pointer-events: none;
  }
  #dc-replay::before { content: "◐"; color: var(--terra); }
  #dc-replay:hover { background: var(--ink); color: var(--cream); border-color: var(--ink); }
  :global(body.cinema-done) #dc-replay { opacity: 1; pointer-events: auto; }

  #dc-hint {
    position: absolute;
    left: 50%;
    bottom: 14vh;
    transform: translateX(-50%);
    z-index: 6;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terra);
    opacity: 0;
    transition: opacity 0.8s ease;
    display: flex;
    align-items: center;
    gap: 10px;
    pointer-events: none;
  }
  #dc-hint::before, #dc-hint::after {
    content: "";
    width: 32px;
    height: 1px;
    background: var(--terra);
  }
  :global(body.cinema-done) #dc-hint { opacity: 0.85; animation: hintPulse 2.4s ease-in-out 1.4s infinite; }
  @keyframes hintPulse {
    0%, 100% { opacity: 0.4; }
    50%      { opacity: 0.95; }
  }

  /* AUDIO TOGGLE — sits next to Skip Ride on top-left */
  #aud-tog {
    position: fixed;
    top: 13vh;
    left: calc(var(--g) + 140px);
    z-index: 55;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(237, 228, 211, 0.92);
    background: rgba(10, 18, 12, 0.85);
    border: 1px solid rgba(237, 228, 211, 0.35);
    padding: 10px 16px;
    border-radius: 99px;
    cursor: none;
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    transition: opacity 0.5s, background 0.25s, color 0.25s;
  }
  #aud-tog:hover { background: var(--terra); color: #fff; border-color: var(--terra); }
  #aud-tog .ad {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--muted);
  }
  #aud-tog.on .ad {
    background: var(--terra);
    box-shadow: 0 0 8px var(--terra);
  }
  :global(body:not(.cinema):not(.cinema-done)) #aud-tog { opacity: 0; pointer-events: none; }

  /* SPREAD MODAL */
  #spread {
    position: fixed;
    inset: 0;
    z-index: 120;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4vh 4vw;
  }
  #spread-bd {
    position: absolute;
    inset: 0;
    background: rgba(10, 18, 12, 0);
    backdrop-filter: blur(0px);
    transition: background 0.55s, backdrop-filter 0.55s;
  }
  #spread.open { pointer-events: auto; }
  #spread.open #spread-bd {
    background: rgba(10, 18, 12, 0.78);
    backdrop-filter: blur(10px);
  }
  #spread-card {
    position: relative;
    width: min(1100px, 92vw);
    max-height: 88vh;
    display: grid;
    grid-template-columns: 46% 54%;
    background: #f7efe0;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 60px 140px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(29, 46, 34, 0.12);
    transform: translateY(60px) rotate(-2deg) scale(0.9);
    opacity: 0;
    transition: transform 0.8s cubic-bezier(0.2, 0.9, 0.2, 1), opacity 0.5s;
  }
  #spread.open #spread-card { transform: translateY(0) rotate(0) scale(1); opacity: 1; }
  .sp-stage { display: contents; }
  .sp-front { position: relative; min-height: 560px; }
  .sp-photo {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: var(--ink);
  }
  .sp-photo .ph-tint { position: absolute; inset: 0; }
  .sp-photo .ph-art { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.55; }
  .sp-photo .ph-grain {
    position: absolute;
    inset: 0;
    opacity: 0.22;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.45 0 0 0 0 0.4 0 0 0 0 0.35 0 0 0 0.7 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }
  .sp-greet {
    position: absolute;
    left: 28px;
    top: 22px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 245, 232, 0.85);
    z-index: 3;
  }
  .sp-city {
    position: absolute;
    left: 28px;
    bottom: 60px;
    right: 28px;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(48px, 5.5vw, 84px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--cream);
    font-variation-settings: 'opsz' 144, 'ital' 1, 'wght' 300;
    z-index: 3;
  }
  .sp-coord {
    position: absolute;
    left: 28px;
    bottom: 24px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(255, 245, 232, 0.65);
    z-index: 3;
  }
  #spread[data-loc="delhi"] .sp-photo .ph-tint { background: linear-gradient(135deg, #c25a3a, #7a3220, #3d1a10); }
  #spread[data-loc="punjab"] .sp-photo .ph-tint { background: linear-gradient(135deg, #d4a85a, #9a6b2a, #5a3818); }
  #spread[data-loc="london"] .sp-photo .ph-tint { background: linear-gradient(135deg, #5a6f7a, #3a4854, #1d2630); }
  #spread[data-loc="usa"] .sp-photo .ph-tint { background: linear-gradient(135deg, #2d4533, #1d2e22, #0a1610); }

  .sp-back {
    padding: 42px 44px 36px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    overflow-y: auto;
    max-height: 88vh;
    position: relative;
    background-image: repeating-linear-gradient(to bottom, transparent 0 26px, rgba(29, 46, 34, 0.05) 26px 27px);
    background-position: 0 90px;
  }
  .sp-stamp { position: absolute; top: 24px; right: 30px; }
  .sp-stamp .pc-stamp-frame { width: 56px; height: 64px; }
  .sp-stamp .pc-stamp-amt { font-size: 18px; }
  .sp-stamp .pc-stamp-flag { width: 28px; height: 18px; }

  .sp-pm {
    position: absolute;
    top: 120px;
    right: 34px;
    width: 120px;
    height: 120px;
    border: 2px solid rgba(29, 46, 34, 0.55);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(29, 46, 34, 0.65);
    transform: rotate(-12deg);
    text-align: center;
    padding: 8px;
    line-height: 1.3;
  }
  .sp-pm .pm-date {
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: rgba(29, 46, 34, 0.85);
    letter-spacing: 0.05em;
    text-transform: none;
    margin: 6px 0;
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }

  .sp-body {
    padding-top: 8px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 90%;
  }
  .sp-eyebrow {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--terra);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sp-eyebrow::before {
    content: "";
    width: 20px;
    height: 1px;
    background: var(--terra);
  }
  .sp-h {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(38px, 4vw, 60px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--ink);
    font-variation-settings: 'opsz' 96, 'wght' 300;
  }
  .sp-h em {
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 96, 'ital' 1, 'wght' 300;
  }
  .sp-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
    color: var(--moss);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
    line-height: 1.4;
    max-width: 48ch;
  }
  .sp-p {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink);
