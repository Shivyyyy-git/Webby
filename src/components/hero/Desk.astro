---
// Sticky-scroll ride. Each entry = one 100vh "stop". Body copy is
// brief-aligned: no em dashes, no invented metrics, no client names.
const SCRIPT = [
  {
    loc: 'delhi',
    title: 'Delhi',
    mood: 'rowdy',
    era: '1994 · Childhood',
    coord: 'N 28.6° · E 77.2°',
    short: 'Delhi',
    body: 'Born loud, raised loud. Five languages by the time I could read one. Negotiation as a survival skill before I knew what product was.',
    cardEyebrow: 'DEPARTING',
    year: '1994',
    cardLoc: 'DELHI · INDIA',
    bullets: ['Era · Childhood', 'Languages · 5', 'Took with me · grit, pace, loud laugh'],
  },
  {
    loc: 'punjab',
    title: 'Punjab',
    mood: 'roots',
    era: 'Every · Summer',
    coord: 'N 31.1° · E 75.3°',
    short: 'Punjab',
    body: 'Family roots. Wheat, dhol, daal, a table where everybody talks at once. Hospitality as a default state. Feed strangers first, ask questions never.',
    cardEyebrow: 'ROOTS',
    year: 'Every summer',
    cardLoc: 'JALANDHAR · INDIA',
    bullets: ['Family from · Jalandhar', 'Languages · Punjabi, Hindi', 'Took with me · warmth, loyalty, bhangra'],
  },
  {
    loc: 'london',
    title: 'London',
    mood: 'built',
    era: '2019 · 2024',
    coord: 'L 51.5° · D 25.2°',
    short: 'London',
    body: 'Two companies in five years. UK and the Middle East. Both sold. Hired teams, took payroll personally when cash was thin, learned product the hard way before I called myself a PM.',
    cardEyebrow: 'FOUNDER',
    year: '$575K combined',
    cardLoc: 'LONDON · DUBAI',
    bullets: ['Era · 2019 to 2024', 'CloudApproach · Approachables', 'Took with me · ship before perfect'],
  },
  {
    loc: 'usa',
    title: 'Rochester',
    mood: 'shipping',
    era: 'Now',
    coord: 'N 43.2° · W 77.6°',
    short: 'Rochester',
    body: 'AI PM at ESC Partners. Built Maya AI end-to-end in about 2.5 months. The only AI person on the team. Customer support for utility companies. Voice, chat, SMS, email, mobile. In pilot with 40+ agents.',
    cardEyebrow: 'NOW BOARDING',
    year: '2026',
    cardLoc: 'ROCHESTER · NY',
    bullets: ['AI PM · ESC Partners', 'Maya AI · 70 to 80% first-touch', 'Open to the next stop'],
  },
];

const POSTCARDS = [
  {
    loc: 'delhi',
    label: 'Delhi · open',
    rotation: '-2.2deg',
    ital: false,
    title: 'Delhi',
    mood: 'Rowdy.',
    stamp: '₹2',
    flag: '',
    pmL: 'DELHI G.P.O.',
    pmDate: '15 · APR · 1995',
    pmR: '★ DEPART ★',
    handwritten: ['born loud, raised loud,', "learned to negotiate before", 'i learned to read.'],
    addrName: "whoever's reading.",
    addrLine: 'somewhere on the internet',
    tape: ['tl', 'br'],
  },
  {
    loc: 'punjab',
    label: 'Punjab · open',
    rotation: '1.6deg',
    ital: true,
    title: 'Punjab',
    mood: 'Roots.',
    stamp: '₹5',
    flag: '',
    pmL: 'JALANDHAR',
    pmDate: 'EVERY · SUMMER',
    pmR: '★ ROOTS ★',
    handwritten: ['family loud at the table.', 'bhangra in the bones,', 'daal on every plate.'],
    addrName: 'anyone with a kitchen.',
    addrLine: 'come hungry.',
    tape: ['tr'],
  },
  {
    loc: 'london',
    label: 'London · open',
    rotation: '-1.4deg',
    ital: false,
    title: 'London',
    mood: 'Built.',
    stamp: '£1',
    flag: 'uk',
    pmL: 'LONDON · DUBAI',
    pmDate: '2019 to 2024',
    pmR: '★ FOUNDER ★',
    handwritten: ['two companies, uk and mena.', 'cloudapproach. approachables.', 'sold both. learned product the hard way.'],
    addrName: "whoever's hiring product.",
    addrLine: '$575K combined exits.',
    tape: ['tl'],
  },
  {
    loc: 'usa',
    label: 'Rochester · open',
    rotation: '2.4deg',
    ital: true,
    title: 'Rochester',
    mood: 'Shipping.',
    stamp: '$1',
    flag: 'us',
    pmL: 'ROCHESTER · NY',
    pmDate: 'NOW',
    pmR: '★ NOW ★',
    handwritten: ['ai pm at esc partners.', 'built maya end-to-end.', 'customer support for utilities.'],
    addrName: 'recruiters at applied-ai orgs.',
    addrLine: 'available now. let\'s talk.',
    tape: ['tr', 'bl'],
  },
];
---
{/* THE RIDE — sticky-scroll cinematic journey. Each SCRIPT entry gets
    one 100vh slide. Train chugs at the bottom and traverses as you scroll.
    Hidden #desk-section below preserves the postcards in DOM so the
    spread modal can still read their inline SVG art on click. */}
<section id="ride-section" aria-label="the ride">
  <div id="ride-driver">
    <div id="ride-sticky">

      {/* Soft landscape: hills + ground band */}
      <svg class="ride-hills" viewBox="0 0 1200 400" preserveAspectRatio="none" aria-hidden="true">
        <path class="hill-far"  d="M0,260 Q300,210 600,250 T1200,230 L1200,400 L0,400 Z" />
        <path class="hill-mid"  d="M0,300 Q260,260 520,290 T1040,290 T1200,280 L1200,400 L0,400 Z" />
        <path class="hill-near" d="M0,340 Q200,310 400,330 T800,330 T1200,320 L1200,400 L0,400 Z" />
      </svg>
      <div class="ride-ground" aria-hidden="true"></div>

      {/* Top HUD: title left, coord center, current stop right */}
      <div class="ride-hud" aria-hidden="true">
        <span class="hud-left">THE RIDE · DELHI → ROCHESTER</span>
        <span class="hud-coord" id="ride-coord">N 28.6° · E 77.2°</span>
        <span class="hud-now" id="ride-now">· DELHI</span>
      </div>

      {/* Coda — "where could we go next?" — appears after the 4 stations,
          when the train reaches the end of the line. Staggered fade-in. */}
      <div class="ride-coda" id="ride-coda" aria-hidden="true">
        <div class="coda-eyebrow"><span class="rule"></span> STOP 05 · ?</div>
        <h2 class="coda-h">where could we go next?</h2>
        <p class="coda-p">your move, recruiter.</p>
      </div>

      {/* Stations — fade in/out as scroll progresses */}
      <div class="ride-stations">
        {SCRIPT.map((s, i) => (
          <article class={`station${i === 0 ? ' active' : ''}`} data-i={i}>
            <div class="station-inner">
              <div class="station-text">
                <div class="station-num">STOP {String(i + 1).padStart(2, '0')} · {s.era}</div>
                <h2 class="station-h">{s.title}<em>.</em></h2>
                <div class="station-mood">· {s.mood}.</div>
                <p class="station-body">{s.body}</p>
                <button class="station-open" data-open={i} type="button">
                  open the postcard <span aria-hidden="true">→</span>
                </button>
              </div>
              <aside class="station-card">
                <span class="card-tape" aria-hidden="true"></span>
                <b>STOP {String(i + 1).padStart(2, '0')} · {s.cardEyebrow}</b>
                <span class="yr">{s.year}</span>
                <span class="ploc">{s.cardLoc}</span>
                <ul>
                  {s.bullets.map((b) => <li>{b}</li>)}
                </ul>
              </aside>
            </div>
          </article>
        ))}
      </div>

      {/* Train track + locomotive */}
      <div class="ride-track" aria-hidden="true">
        <div class="ride-ties"></div>
        <div class="ride-rail"></div>
        <svg id="ride-train" viewBox="0 0 160 48" xmlns="http://www.w3.org/2000/svg">
          <g class="smoke">
            <circle cx="14" cy="10" r="2.5" />
            <circle cx="11" cy="6"  r="3" />
            <circle cx="16" cy="2"  r="3.5" />
          </g>
          <rect x="2"  y="18" width="44" height="22" rx="2" fill="#1d2e22" />
          <rect x="6"  y="13" width="14" height="6" fill="#1d2e22" />
          <rect x="11" y="8"  width="6"  height="6" fill="#1d2e22" />
          <rect x="32" y="22" width="8"  height="8" fill="#ede4d3" />
          <rect x="0"  y="31" width="48" height="2" fill="#c25a3a" />
          <rect x="46" y="28" width="6"  height="2" fill="#1d2e22" />
          <rect x="50" y="21" width="48" height="19" rx="1.5" fill="#c25a3a" />
          <rect x="56" y="24" width="6"  height="6" fill="#ede4d3" />
          <rect x="66" y="24" width="6"  height="6" fill="#ede4d3" />
          <rect x="76" y="24" width="6"  height="6" fill="#ede4d3" />
          <rect x="86" y="24" width="6"  height="6" fill="#ede4d3" />
          <rect x="96" y="28" width="6"  height="2" fill="#1d2e22" />
          <rect x="100" y="21" width="48" height="19" rx="1.5" fill="#2d4533" />
          <rect x="106" y="24" width="6"  height="6" fill="#ede4d3" />
          <rect x="116" y="24" width="6"  height="6" fill="#ede4d3" />
          <rect x="126" y="24" width="6"  height="6" fill="#ede4d3" />
          <rect x="136" y="24" width="6"  height="6" fill="#ede4d3" />
          <circle cx="10"  cy="42" r="4"   fill="#1d2e22" />
          <circle cx="36"  cy="42" r="4"   fill="#1d2e22" />
          <circle cx="60"  cy="42" r="3.2" fill="#1d2e22" />
          <circle cx="88"  cy="42" r="3.2" fill="#1d2e22" />
          <circle cx="110" cy="42" r="3.2" fill="#1d2e22" />
          <circle cx="138" cy="42" r="3.2" fill="#1d2e22" />
        </svg>
      </div>

      {/* Bottom progress timeline */}
      <div class="ride-progress" aria-hidden="true">
        <div class="rp-line">
          <div class="rp-fill" id="rp-fill"></div>
          {SCRIPT.map((s, i) => (
            <div class={`rp-stop${i === 0 ? ' lit' : ''}`} data-i={i} style={`left:${(i / (SCRIPT.length - 1)) * 100}%`}>
              <span class="lbl">{s.short}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

{/* Hidden — preserved so the spread modal can read each postcard's
    inline SVG art. Display:none in CSS; .pcard click handlers still wire. */}
<div id="desk-section" hidden>
  <div id="desk">
    <div id="desk-grain"></div>
    <div id="desk-rail">
      <div id="desk-strip">
        {POSTCARDS.map((p, i) => (
          <article class="pcard" data-loc={p.loc} data-i={i} data-cur="proj" data-cur-lbl={p.label} style={`--rot:${p.rotation}`}>
            <div class="pc-front">
              <div class="pc-photo">
                <div class="ph-tint"></div>
                {p.loc === 'delhi' && (
                  <svg class="ph-art" viewBox="0 0 200 120" preserveAspectRatio="xMidYMid slice">
                    <path d="M0,90 L200,90" stroke="#1d1208" stroke-width="2" opacity=".4" />
                    <circle cx="40" cy="92" r="14" fill="none" stroke="#1d1208" stroke-width="2" opacity=".55" />
                    <circle cx="40" cy="92" r="5" fill="#1d1208" opacity=".55" />
                    <path d="M30,92 L34,60 L60,55 L72,90" fill="none" stroke="#1d1208" stroke-width="2" opacity=".55" />
                    <path d="M120,90 L120,55 L160,55 L160,90" fill="none" stroke="#1d1208" stroke-width="2" opacity=".55" />
                    <path d="M125,55 L155,55 L150,40 L130,40 Z" fill="#1d1208" opacity=".4" />
                    <path d="M132,38 Q128,28 134,18" fill="none" stroke="#1d1208" stroke-width="1.5" opacity=".35" stroke-linecap="round" />
                    <path d="M142,38 Q138,26 144,14" fill="none" stroke="#1d1208" stroke-width="1.5" opacity=".35" stroke-linecap="round" />
                  </svg>
                )}
                {p.loc === 'punjab' && (
                  <svg class="ph-art" viewBox="0 0 200 120" preserveAspectRatio="xMidYMid slice">
                    <circle cx="160" cy="36" r="20" fill="#ffe9b8" opacity=".4" />
                    <path d="M0,90 Q50,82 100,90 Q150,98 200,88" fill="#3d2510" opacity=".4" />
                    <path d="M0,100 Q60,94 100,100 Q150,108 200,98" fill="#3d2510" opacity=".5" />
                    <g stroke="#3d2510" stroke-width="1.2" opacity=".5">
                      <line x1="20" y1="90" x2="20" y2="74" /><line x1="22" y1="76" x2="18" y2="74" />
                      <line x1="40" y1="92" x2="40" y2="72" /><line x1="42" y1="74" x2="38" y2="72" />
                      <line x1="60" y1="90" x2="60" y2="76" /><line x1="62" y1="78" x2="58" y2="76" />
                      <line x1="80" y1="91" x2="80" y2="72" /><line x1="82" y1="74" x2="78" y2="72" />
                      <line x1="100" y1="92" x2="100" y2="74" /><line x1="102" y1="76" x2="98" y2="74" />
                    </g>
                    <ellipse cx="120" cy="60" rx="18" ry="11" fill="#3d2510" opacity=".5" />
                    <path d="M102,60 Q102,44 120,38 Q138,44 138,60" fill="#3d2510" opacity=".55" />
                  </svg>
                )}
                {p.loc === 'london' && (
                  <svg class="ph-art" viewBox="0 0 200 120" preserveAspectRatio="xMidYMid slice">
                    <line x1="0" y1="90" x2="200" y2="90" stroke="#0a1018" stroke-width="2" opacity=".4" />
                    <rect x="34" y="34" width="22" height="60" fill="none" stroke="#0a1018" stroke-width="1.5" opacity=".5" />
                    <polygon points="34,34 56,34 45,18" fill="#0a1018" opacity=".5" />
                    <circle cx="45" cy="50" r="5" fill="none" stroke="#0a1018" stroke-width="1" opacity=".55" />
                    <line x1="45" y1="50" x2="45" y2="46" stroke="#0a1018" stroke-width="1" opacity=".55" />
                    <line x1="45" y1="50" x2="48" y2="50" stroke="#0a1018" stroke-width="1" opacity=".55" />
                    <path d="M70,90 Q120,70 170,90" fill="none" stroke="#0a1018" stroke-width="1.5" opacity=".5" />
                    <line x1="80" y1="83" x2="80" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <line x1="100" y1="78" x2="100" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <line x1="120" y1="76" x2="120" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <line x1="140" y1="78" x2="140" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <line x1="160" y1="83" x2="160" y2="90" stroke="#0a1018" stroke-width="1" opacity=".4" />
                    <g stroke="#dde6ec" stroke-width="0.6" opacity=".25">
                      <line x1="10" y1="0" x2="20" y2="20" /><line x1="50" y1="0" x2="60" y2="20" /><line x1="90" y1="0" x2="100" y2="20" /><line x1="130" y1="0" x2="140" y2="20" /><line x1="170" y1="0" x2="180" y2="20" />
                    </g>
                  </svg>
                )}
                {p.loc === 'usa' && (
                  <svg class="ph-art" viewBox="0 0 200 120" preserveAspectRatio="xMidYMid slice">
                    <g fill="#0a0d08" opacity=".55">
                      <rect x="10" y="50" width="14" height="48" />
                      <rect x="28" y="38" width="18" height="60" />
                      <rect x="50" y="58" width="12" height="40" />
                      <rect x="66" y="22" width="22" height="76" />
                      <rect x="92" y="44" width="14" height="54" />
                      <rect x="110" y="32" width="20" height="66" />
                      <rect x="134" y="56" width="12" height="42" />
                      <rect x="150" y="40" width="18" height="58" />
                      <rect x="172" y="60" width="14" height="38" />
                    </g>
                    <g fill="#ffd97a" opacity=".7">
                      <rect x="32" y="44" width="3" height="3" /><rect x="38" y="50" width="3" height="3" />
                      <rect x="70" y="30" width="3" height="3" /><rect x="76" y="40" width="3" height="3" /><rect x="82" y="50" width="3" height="3" />
                      <rect x="114" y="40" width="3" height="3" /><rect x="120" y="48" width="3" height="3" />
                      <rect x="154" y="48" width="3" height="3" /><rect x="160" y="56" width="3" height="3" />
                    </g>
                    <line x1="0" y1="100" x2="200" y2="100" stroke="#c25a3a" stroke-width="1.2" opacity=".7" />
                  </svg>
                )}
                <div class="ph-grain"></div>
                <div class="pc-stamp-ph">{p.loc === 'usa' ? 'ROCHESTER' : p.loc.toUpperCase()}</div>
              </div>
              <div class="pc-text">
                <span class="pc-greet">Greetings from</span>
                <h3 class={`pc-city ${p.ital ? 'ital' : ''}`}>{p.title}<span class="pc-amp">.</span></h3>
                <span class="pc-mood">{p.mood}</span>
              </div>
            </div>
            <div class="pc-back">
              <div class="pc-stamp">
                <div class="pc-stamp-frame">
                  <span class="pc-stamp-amt">{p.stamp}</span>
                  <span class={`pc-stamp-flag ${p.flag}`}></span>
                </div>
              </div>
              <div class="pc-postmark">
                <span>{p.pmL}</span><span class="pm-date">{p.pmDate}</span><span>{p.pmR}</span>
              </div>
              <div class="pc-handwritten">
                {p.handwritten.map((line) => <span class="pc-hw-line">{line}</span>)}
              </div>
              <div class="pc-addr">
                <span class="pc-addr-to">To:</span>
                <span class="pc-addr-name">{p.addrName}</span>
                <span class="pc-addr-line">{p.addrLine}</span>
              </div>
            </div>
            {p.tape.map((t) => <div class={`pc-tape pc-tape-${t}`}></div>)}
          </article>
        ))}

        {/* RAILWAY TRACK — single side-view rail with ties below */}
        <div id="desk-track" aria-hidden="true">
          <div class="track-ties"></div>
          <div class="track-rail"></div>
          {POSTCARDS.map((p, i) => (
            <div class="track-station" data-i={i}>
              <span class="st-dot"></span>
              <span class="st-label">
                <b>{String(i + 1).padStart(2, '0')}</b>
                {p.loc === 'usa' ? 'NY · BOS' : p.loc.charAt(0).toUpperCase() + p.loc.slice(1)}
              </span>
            </div>
          ))}
          <svg id="desk-train" viewBox="0 0 160 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <g class="smoke">
              <circle cx="14" cy="10" r="2.5" />
              <circle cx="11" cy="6"  r="3" />
              <circle cx="16" cy="2"  r="3.5" />
            </g>
            {/* Locomotive */}
            <rect x="2"  y="18" width="44" height="22" rx="2" fill="#1d2e22" />
            <rect x="6"  y="13" width="14" height="6" fill="#1d2e22" />
            <rect x="11" y="8"  width="6"  height="6" fill="#1d2e22" />
            <rect x="32" y="22" width="8"  height="8" fill="#ede4d3" />
            <rect x="0"  y="31" width="48" height="2" fill="#c25a3a" />
            {/* Coupler 1 */}
            <rect x="46" y="28" width="6" height="2" fill="#1d2e22" />
            {/* Carriage 1 */}
            <rect x="50" y="21" width="48" height="19" rx="1.5" fill="#c25a3a" />
            <rect x="56" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="66" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="76" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="86" y="24" width="6" height="6" fill="#ede4d3" />
            {/* Coupler 2 */}
            <rect x="96" y="28" width="6" height="2" fill="#1d2e22" />
            {/* Carriage 2 */}
            <rect x="100" y="21" width="48" height="19" rx="1.5" fill="#2d4533" />
            <rect x="106" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="116" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="126" y="24" width="6" height="6" fill="#ede4d3" />
            <rect x="136" y="24" width="6" height="6" fill="#ede4d3" />
            {/* Wheels */}
            <circle cx="10"  cy="42" r="4"   fill="#1d2e22" />
            <circle cx="36"  cy="42" r="4"   fill="#1d2e22" />
            <circle cx="60"  cy="42" r="3.2" fill="#1d2e22" />
            <circle cx="88"  cy="42" r="3.2" fill="#1d2e22" />
            <circle cx="110" cy="42" r="3.2" fill="#1d2e22" />
            <circle cx="138" cy="42" r="3.2" fill="#1d2e22" />
          </svg>
        </div>
      </div>
    </div>

    <div id="desk-cine">
      <div class="dcb top">
        <div class="dcb-meta">
          <span><span class="rec-dot"></span>REC · Roots Reel · 4 stops</span>
          <span id="dc-counter">stop 01 · of 04</span>
        </div>
      </div>
      <div class="dcb bot">
        <div class="dcb-meta">
          <span>auto-pan · click any postcard to open</span>
          <span id="dc-loc">Delhi → Rochester</span>
        </div>
      </div>
    </div>

    <button id="dc-skip">skip ride</button>
    <button id="aud-tog"><span class="ad"></span>sound off</button>
    <button id="dc-replay">replay</button>
    <div id="dc-hint">drag the strip · click any postcard</div>

    {/* Closing kicker — appears after the postcard ride finishes. Forward-
        looking, italic, asks the viewer where the story goes next. */}
    <div id="dc-coda" aria-hidden="true">
      <span class="dc-coda-eyebrow">stop 05 · ?</span>
      <span class="dc-coda-h">where could we go next?</span>
      <span class="dc-coda-p">your move, recruiter.</span>
    </div>

    <div id="dc-caption">
      <span class="dcc-eyebrow" id="dcc-eyebrow">stop 01 · 1995</span>
      <h2 class="dcc-h" id="dcc-h">Delhi.</h2>
      <p class="dcc-p" id="dcc-p">born loud · raised loud</p>
    </div>
  </div>

  <div class="hero-scroll">scroll · or drag the postcards</div>
</div>

<!-- POSTCARD SPREAD MODAL -->
<div id="spread">
  <div id="spread-bd"></div>
  <div id="spread-card">
    <button class="sp-close" id="sp-close" aria-label="Close">×</button>
    <div class="sp-stage">
      <div class="sp-front">
        <div class="sp-photo">
          <div class="ph-tint"></div>
