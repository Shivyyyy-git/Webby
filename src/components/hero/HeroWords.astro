      <span>DELHI</span><span>PUNJAB</span><span>LONDON</span><span>DUBAI</span><span>BUFFALO</span><span>ROCHESTER</span><span>JALANDHAR</span><span>UK&nbsp;·&nbsp;MENA</span>
    </div>
    <div class="hb-row hb-row-3">
      <span>SHIPPING</span><span>FASTAPI</span><span>REACT</span><span>BEDROCK</span><span>DYNAMODB</span><span>ORACLE&nbsp;CCS</span><span>VOICE</span><span>CHAT</span><span>SMS</span>
      <span>SHIPPING</span><span>FASTAPI</span><span>REACT</span><span>BEDROCK</span><span>DYNAMODB</span><span>ORACLE&nbsp;CCS</span><span>VOICE</span><span>CHAT</span><span>SMS</span>
    </div>
    <div class="hb-row hb-row-4">
      <span>UTILITIES</span><span>SUPPORT</span><span>AGENT&nbsp;CONSOLE</span><span>FIRST-TOUCH</span><span>BORING&nbsp;INDUSTRIES</span><span>SHIP&nbsp;UGLY&nbsp;TUESDAY</span>
      <span>UTILITIES</span><span>SUPPORT</span><span>AGENT&nbsp;CONSOLE</span><span>FIRST-TOUCH</span><span>BORING&nbsp;INDUSTRIES</span><span>SHIP&nbsp;UGLY&nbsp;TUESDAY</span>
    </div>
    <div class="hb-row hb-row-5">
      <span>TWO&nbsp;EXITS</span><span>$575K&nbsp;COMBINED</span><span>40+&nbsp;AGENTS&nbsp;IN&nbsp;PILOT</span><span>2.5&nbsp;MONTHS</span><span>SIMON&nbsp;MS&nbsp;AI</span>
      <span>TWO&nbsp;EXITS</span><span>$575K&nbsp;COMBINED</span><span>40+&nbsp;AGENTS&nbsp;IN&nbsp;PILOT</span><span>2.5&nbsp;MONTHS</span><span>SIMON&nbsp;MS&nbsp;AI</span>
    </div>
  </div>

  <div class="hero-top">
    <div class="cap"><b>Index №01</b> · Delhi → Punjab → London → Rochester</div>
    <div id="local-time">— : — local</div>
  </div>

  <div class="hero-stack">
    <h1 class="hero-name" id="hero-name">
      <span class="word"><span>shivam</span></span>
      <span class="word ital"><span>sharma.</span></span>
    </h1>
    <p class="hero-sub">
      <span class="hs-line">An AI PM who builds <em>end-to-end</em>. Two exits. Now shipping Maya.</span>
      <span class="hs-cta">→ four postcards. one ride. flip any one over.</span>
    </p>
