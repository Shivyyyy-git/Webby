</div>

<style>
  #hero { min-height: 200vh; display: block; padding: 0; position: relative; overflow: hidden; }
  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 5vh var(--g) 0;
    position: relative;
    z-index: 6;
  }
  .hero-top .cap b { color: var(--ink); font-weight: 600; }
  #local-time {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: right;
  }

  #hero-words {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 10vh var(--g) 6vh;
    z-index: 5;
    overflow: hidden;
  }

  /* Animated background — multi-row word marquees that idle-scroll behind the
     name. Wodniack.dev-inspired. Pure CSS, no JS, GPU-accelerated transforms. */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
    user-select: none;
  }
  .hb-row {
    position: absolute;
    left: 0;
    display: inline-flex;
    white-space: nowrap;
    color: var(--ink);
    opacity: 0.055;
    font-family: var(--mono);
    font-size: clamp(46px, 7vw, 110px);
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    will-change: transform;
    line-height: 1;
  }
  .hb-row span {
    padding: 0 28px;
    flex-shrink: 0;
  }
  .hb-row-1 {
    top: 4%;
    animation: hb-scroll 64s linear infinite;
  }
  .hb-row-2 {
    top: 22%;
    animation: hb-scroll 88s linear infinite reverse;
    color: var(--terra);
    opacity: 0.06;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
  }
  .hb-row-3 {
    top: 42%;
    animation: hb-scroll 56s linear infinite;
    opacity: 0.05;
  }
  .hb-row-4 {
    top: 62%;
    animation: hb-scroll 96s linear infinite reverse;
    color: var(--moss);
    opacity: 0.07;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
  }
  .hb-row-5 {
    top: 82%;
    animation: hb-scroll 72s linear infinite;
    opacity: 0.05;
  }
  @keyframes hb-scroll {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-50%, 0, 0); }
  }
  /* Slight darkening at hover/scroll for life — disabled on reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .hb-row { animation: none !important; }
  }
  #hero-words .hero-stack { margin-bottom: 8vh; }
  .hero-stack { margin-top: 0; position: relative; z-index: 6; }
  .hero-w { position: relative; z-index: 6; }
  .hero-stack {
    transition: opacity 0.8s ease, filter 0.8s ease, transform 0.8s ease;
  }
  :global(body.cinema) .hero-stack {
    opacity: 0;
    filter: blur(8px);
    transform: translateY(20px);
    pointer-events: none;
  }
  :global(body.cinema) .hero-foot,
  :global(body.cinema) .hero-top,
  :global(body.cinema) .hero-sub {
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }
  :global(body.cinema) :global(#np),
  :global(body.cinema) :global(#ask) {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .hero-name {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(60px, 10.5vw, 170px);
    line-height: 0.82;
    letter-spacing: -0.055em;
    color: var(--ink);
    font-variation-settings: 'opsz' 144, 'wght' 300;
    text-transform: lowercase;
    position: relative;
    z-index: 2;
  }
  .hero-name .ital {
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 144, 'ital' 1, 'wght' 300;
  }
  .hero-name .word {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    line-height: 0.95;
    padding: 0 0.04em 0.14em;
  }
  .hero-name .word > span {
    display: inline-block;
    will-change: transform;
    transform: translateY(110%);
    transition: transform 1.1s cubic-bezier(0.2, 0.9, 0.2, 1);
  }
  .hero-name .word.in > span { transform: translateY(0) !important; }

  .hero-sub {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 640px;
  }
  .hero-sub .hs-line {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(20px, 1.8vw, 28px);
    color: var(--ink);
    font-variation-settings: 'opsz' 36, 'wght' 300;
    line-height: 1.3;
  }
  .hero-sub .hs-line em {
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 36, 'ital' 1, 'wght' 400;
  }
  .hero-sub .hs-cta {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Polaroid portrait — bumped up size, no grain overlay so the actual
     photograph reads clean. */
  #hero-photo {
    position: absolute;
    top: 6%;
    right: 5%;
    width: clamp(280px, 30vw, 480px);
    aspect-ratio: 3 / 4;
    background: var(--paper);
    padding: 16px 16px 62px;
    border-radius: 4px;
    box-shadow:
      0 40px 100px -10px rgba(29, 46, 34, 0.28),
      0 12px 24px -6px rgba(29, 46, 34, 0.16),
      0 0 0 1px rgba(29, 46, 34, 0.06);
    transform: rotate(2deg) translateY(28px);
    opacity: 0;
    transition: opacity 0.9s ease 1s, transform 1.4s cubic-bezier(0.2, 0.9, 0.2, 1) 0.9s;
    z-index: 4;
    perspective: 800px;
    transform-style: preserve-3d;
    cursor: none;
    margin: 0;
  }
  #hero-photo.in {
    opacity: 1;
    transform: rotate(2deg) translateY(0);
  }
  /* A small piece of "tape" at the top */
  #hero-photo::after {
    content: "";
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    width: 84px;
    height: 22px;
    background: rgba(212, 180, 140, 0.55);
    background-image: repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.16) 0 2px, transparent 2px 6px);
    box-shadow: 0 1px 2px rgba(29, 46, 34, 0.14);
    z-index: 6;
    pointer-events: none;
  }
  .hp-frame {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 2px;
    background: var(--ink);
  }
  #hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: contrast(1.02) saturate(0.95);
  }
  #hero-photo figcaption {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .hp-name {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 16px;
    color: var(--ink);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 400;
  }
  .hp-meta {
    font-family: var(--mono);
    font-size: 8px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
  }
  :global(body.cinema) #hero-photo {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  @media (max-width: 900px) {
    #hero-photo {
      position: relative;
      top: auto;
      right: auto;
      margin: 32px auto 0;
      width: min(280px, 70%);
    }
  }

  .hero-foot {
    margin-top: 8vh;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 56px;
    align-items: start;
    position: relative;
    z-index: 6;
  }
  .hero-bio {
    font-family: var(--sans);
    font-size: clamp(15px, 1.1vw, 17px);
    line-height: 1.55;
    color: var(--ink);
    max-width: 640px;
  }
  .hero-bio em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--terra);
    font-variation-settings: 'opsz' 24, 'ital' 1, 'wght' 500;
  }
  .hero-meta {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .hero-meta div {
    margin-bottom: 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero-meta b {
    color: var(--ink);
    font-weight: 500;
    letter-spacing: 0.06em;
    font-size: 11px;
  }

  @media (max-width: 900px) {
    .hero-foot { grid-template-columns: 1fr; gap: 24px; }
  }
</style>
