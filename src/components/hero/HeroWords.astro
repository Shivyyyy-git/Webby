<div id="hero-words" class="w hero-w">
  {/* Animated background — five rows of softly-drifting identity words, very
      low contrast, idle motion. Inspired by wodniack.dev's binary rows.
      All vocabulary anchored to the brief: real companies, real cities, real
      stack, real metrics. Nothing invented. */}
  <div class="hero-bg" aria-hidden="true">
    <div class="hb-row hb-row-1">
      <span>AI&nbsp;·&nbsp;PM</span><span>BUILDER</span><span>MAYA&nbsp;AI</span><span>ESC&nbsp;PARTNERS</span><span>VOLLIE</span><span>CLOUDAPPROACH</span><span>APPROACHABLES</span><span>END-TO-END</span>
      <span>AI&nbsp;·&nbsp;PM</span><span>BUILDER</span><span>MAYA&nbsp;AI</span><span>ESC&nbsp;PARTNERS</span><span>VOLLIE</span><span>CLOUDAPPROACH</span><span>APPROACHABLES</span><span>END-TO-END</span>
    </div>
    <div class="hb-row hb-row-2">
